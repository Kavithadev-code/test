from __future__ import annotations

from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional


def _get(data: Optional[Dict[str, Any]], *keys: str, default=None):
    """
    Return the first matching key from a dict.
    Supports both camelCase and snake_case inputs.
    """
    if not isinstance(data, dict):
        return default

    for key in keys:
        if key in data and data[key] is not None:
            return data[key]
    return default


def _get_list(data: Optional[Dict[str, Any]], *keys: str) -> List[Any]:
    value = _get(data, *keys, default=[])
    return value if isinstance(value, list) else []


@dataclass
class Address:
    global_identifier: Optional[str] = None
    primary_ind: Optional[bool] = None
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "Address":
        if not isinstance(data, dict):
            return cls()

        return cls(
            global_identifier=_get(data, "globalIdentifier", "global_identifier"),
            primary_ind=_get(data, "primaryInd", "primary_ind"),
            unknown_fields=data,
        )


