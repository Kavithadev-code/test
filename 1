@dataclass
class Party:
    party_code: Optional[str] = None
    party_role_seq_no: Optional[int] = None
    individual_name: Optional[Name] = None
    entity_name: Optional[Name] = None
    mailing_addresses: List[MailingAddress] = field(default_factory=list)
    electronic_addresses: List[ElectronicAddress] = field(default_factory=list)
    telecom_addresses: List[TelecomAddress] = field(default_factory=list)
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "Party":
        if not isinstance(data, dict):
            return cls()

        mailing_addresses = [
            MailingAddress.from_dict(item)
            for item in _get_list(data, "mailingAddresses", "mailing_addresses")
        ]

        electronic_addresses = [
            ElectronicAddress.from_dict(item)
            for item in _get_list(data, "electronicAddresses", "electronic_addresses")
        ]

        telecom_addresses = [
            TelecomAddress.from_dict(item)
            for item in _get_list(data, "telecomAddresses", "telecom_addresses")
        ]

        return cls(
            party_code=_get(data, "partyCode", "party_code"),
            party_role_seq_no=_get(data, "partyRoleSeqNo", "party_role_seq_no"),
            individual_name=Name.from_dict(
                _get(data, "individualName", "individual_name", default={})
            ),
            entity_name=Name.from_dict(
                _get(data, "entityName", "entity_name", default={})
            ),
            mailing_addresses=mailing_addresses,
            electronic_addresses=electronic_addresses,
            telecom_addresses=telecom_addresses,
            unknown_fields=data,
        )


@dataclass
class Trademark:
    registration_number: Optional[str] = None
    serial_number: Optional[str] = None
    mark_description: Optional[str] = None
    owners: List[Party] = field(default_factory=list)
    prior_owners: List[Party] = field(default_factory=list)
    correspondent: Optional[Party] = None
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "Trademark":
        if not isinstance(data, dict):
            return cls()

        owners = [Party.from_dict(item) for item in _get_list(data, "owners")]
        prior_owners = [
            Party.from_dict(item)
            for item in _get_list(data, "priorOwners", "prior_owners")
        ]

        correspondent_raw = _get(data, "correspondent", default=None)

        return cls(
            registration_number=_get(data, "registrationNumber", "registration_number"),
            serial_number=_get(data, "serialNumber", "serial_number"),
            mark_description=_get(data, "markDescription", "mark_description"),
            owners=owners,
            prior_owners=prior_owners,
            correspondent=Party.from_dict(correspondent_raw) if correspondent_raw else None,
            unknown_fields=data,
        )
