environment = config.environment
print("environment from config:", environment)

if not environment:
    raise ValueError("config.environment is not set")

if environment not in config.ENV_CONFIG:
    raise ValueError(
        f"Invalid environment '{environment}'. Valid values are: {list(config.ENV_CONFIG.keys())}"
    )

SessionLocal = sessionmaker(
    bind=get_engine(config.ENV_CONFIG[environment]["DB_USER_SECRET_ARN"])
)
