from __future__ import annotations

from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional


def _get(data: Optional[Dict[str, Any]], *keys: str, default=None):
    if not isinstance(data, dict):
        return default
    for key in keys:
        if key in data:
            return data[key]
    return default


@dataclass
class IpInfo:
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    id: Optional[str] = None
    name: Optional[str] = None
    party_code: Optional[str] = None
    composed_of: Optional[str] = None
    legal_entity: Optional[str] = None
    legal_entity_statement_tx: Optional[str] = None
    given_name: Optional[str] = None
    suffix: Optional[str] = None
    middle_name: Optional[str] = None
    family_name: Optional[str] = None
    prefix_name: Optional[str] = None
    individual_minor_indicator: Optional[str] = None
    primary_EAG_id: Optional[str] = None
    assumed_name: Optional["AssumedName"] = None
    contact_address: Optional["ContactAddress"] = None
    citizenship: Optional["Citizenship"] = None

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "IpInfo":
        if not isinstance(data, dict):
            return cls()

        return cls(
            unknown_fields=data,
            id=_get(data, "id"),
            name=_get(data, "name"),
            party_code=_get(data, "partyCode", "party_code"),
            composed_of=_get(data, "composedOf", "composed_of"),
            legal_entity=_get(data, "legalEntity", "legal_entity"),
            legal_entity_statement_tx=_get(
                data, "legalEntityStatementTx", "legal_entity_statement_tx"
            ),
            given_name=_get(data, "givenName", "given_name"),
            suffix=_get(data, "suffix"),
            middle_name=_get(data, "middleName", "middle_name"),
            family_name=_get(data, "familyName", "family_name"),
            prefix_name=_get(data, "prefixName", "prefix_name"),
            individual_minor_indicator=_get(
                data, "individualMinorIndicator", "individual_minor_indicator"
            ),
            primary_EAG_id=_get(data, "primaryEAGid", "primary_EAG_id"),
            assumed_name=AssumedName.from_dict(_get(data, "assumedName", "assumed_name")),
            contact_address=ContactAddress.from_dict(
                _get(data, "contactAddress", "contact_address")
            ),
            citizenship=Citizenship.from_dict(_get(data, "citizenship")),
        )


@dataclass
class Owner:
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    owner_sequence_no: Optional[int] = None
    party_role_seq_no: Optional[int] = None
    tm_party_role_id: Optional[int] = None
    docket_reference_no: Optional[str] = None
    email_authorized: Optional[str] = None
    ip_info: Optional[IpInfo] = None
    owner_type_cd: Optional[str] = None
    reel_number: Optional[str] = None
    frame_number: Optional[str] = None
    assignment_name_change: Optional[str] = None
    assignment_date: Optional[str] = None

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "Owner":
        if not isinstance(data, dict):
            return cls()

        return cls(
            unknown_fields=data,
            owner_sequence_no=_get(data, "ownerSequenceNo", "owner_sequence_no"),
            party_role_seq_no=_get(data, "partyRoleSeqNo", "party_role_seq_no"),
            tm_party_role_id=_get(data, "tmPartyRoleId", "tm_party_role_id"),
            docket_reference_no=_get(data, "docketReferenceNo", "docket_reference_no"),
            email_authorized=_get(data, "emailAuthorized", "email_authorized"),
            ip_info=IpInfo.from_dict(_get(data, "ipInfo", "ip_info")),
            owner_type_cd=_get(data, "ownerTypeCd", "owner_type_cd"),
            reel_number=_get(data, "reelNumber", "reel_number"),
            frame_number=_get(data, "frameNumber", "frame_number"),
            assignment_name_change=_get(
                data, "assignmentNameChange", "assignment_name_change"
            ),
            assignment_date=_get(data, "assignmentDate", "assignment_date"),
        )


@dataclass
class Trademark:
    unknown_fields: Dict[str, Any] = field(default_factory=dict)

    prior_owners: List[Owner] = field(default_factory=list)
    owners: List[Owner] = field(default_factory=list)
    registration_number: Optional[int] = None

    @classmethod
    def from_dict(cls, data: Optional[Dict[str, Any]]) -> "Trademark":
        if not isinstance(data, dict):
            return cls()

        prior_owners_raw = _get(data, "priorOwners", "prior_owners", default=[]) or []
        owners_raw = _get(data, "owners", default=[]) or []

        return cls(
            unknown_fields=data,
            prior_owners=[Owner.from_dict(item) for item in prior_owners_raw],
            owners=[Owner.from_dict(item) for item in owners_raw],
            registration_number=_get(
                data, "registrationNumber", "registration_number"
            ),
        )
