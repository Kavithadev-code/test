@dataclass(frozen=True)
class ClaimedMadridEvent:
    batch_id: str
    event_id: int
    event_type: str
    serial_number: str


class MadridEventRepository:
    def __init__(self, session):
        self.session = session

    def claim_pending_events(self) -> ClaimedMadridEvent | None:
        """
        Claims ONE NEW madrid event and marks it to PROCESSING.
        Returns ClaimedMadridEvent or None if nothing to process.
        """
        import uuid

        unique_id = uuid.uuid4().hex

        try:
            logger.info("Claiming the Madrid event with batch id: %s", unique_id)

            # status id for NEW
            new_status_sq = select(StandardStatus.status_id).where(
                StandardStatus.status_code == AssignmentStatus.MADRID_NEW.value
            )

            # select one oldest NEW event (lock it so no other worker can claim it)
            select_stmt = (
                select(MadridEvent.event_id, MadridEvent.event_type, MadridEvent.serial_number)
                .where(MadridEvent.fk_status_id == new_status_sq.scalar_subquery())
                .order_by(MadridEvent.event_date.asc())
                .limit(1)
                .with_for_update(skip_locked=True)  # ✅ prevents double claim (DB must support it)
            )

            row = self.session.execute(select_stmt).first()
            if not row:
                logger.info("No New Madrid event found")
                self.session.rollback()  # good hygiene if DB opened a txn
                return None

            event_id, event_type, serial_number = row

            # status id for PROCESSING
            processing_status_sq = select(StandardStatus.status_id).where(
                StandardStatus.status_code == AssignmentStatus.MADRID_PROCESSING.value
            )

            update_stmt = (
                update(MadridEvent)
                .values(
                    fk_status_id=processing_status_sq.scalar_subquery(),
                    batch_id=unique_id,
                )
                .where(MadridEvent.event_id == event_id)
            )

            self.session.execute(update_stmt)
            self.session.commit()

            logger.info("Successfully claimed Madrid event_id=%s batch_id=%s", event_id, unique_id)

            return ClaimedMadridEvent(
                batch_id=unique_id,
                event_id=event_id,
                event_type=event_type,
                serial_number=serial_number,  # ✅ fixed key/field
            )

        except SQLAlchemyError:
            logger.exception("DB error occurred while claiming Madrid event")
            self.session.rollback()
            raise
        except Exception:
            logger.exception("Error occurred while claiming Madrid event")
            self.session.rollback()
            raise














