    def finalize_event_status(
        self,
        event_id: int,
        status: AssignmentStatus,
        assignment_id: int | None = None,
        error_msg: str | None = None,
    ) -> None:
        """Finalizing the madrid event as PROCESSED or FAILED."""
        try:
            logger.info(
                "Finalizing Madrid event_id=%s with status=%s",
                event_id,
                status.value,
            )

            status_sq = select(StandardStatus.status_id).where(
                StandardStatus.status_code == status.value
            )

            value_dict: dict = {
                "fk_status_id": status_sq.scalar_subquery(),
            }

            # ✅ success path
            if status == AssignmentStatus.MADRID_PROCESSED:
                value_dict["processing_date"] = datetime.now()
                value_dict["assignment_id"] = assignment_id
                value_dict["error_message"] = None

            # ✅ failure path (fix: was incorrectly checking MADRID_NEW in your code)
            if status == AssignmentStatus.MADRID_FAIL:
                value_dict["error_message"] = error_msg or "Unknown error"
                # optional: you might want to clear assignment_id on fail
                # value_dict["assignment_id"] = None

            update_stmt = (
                update(MadridEvent)
                .values(**value_dict)
                .where(MadridEvent.event_id == event_id)
            )

            self.session.execute(update_stmt)
            self.session.commit()

            logger.info("Successfully updated Madrid event status for event_id=%s", event_id)

        except SQLAlchemyError:
            logger.exception("DB error occurred while finalizing Madrid event status event_id=%s", event_id)
            self.session.rollback()
            raise
        except Exception:
            logger.exception("Error occurred while finalizing Madrid event status event_id=%s", event_id)
            self.session.rollback()
