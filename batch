class MadridBatchRunner:
    def __init__(self, madrid_event_repo: MadridEventRepository, processor, logger):
        self.madrid_event_repo = madrid_event_repo
        self.processor = processor
        self._logger = logger

    def process_madrid(self, event_id: int | None = None) -> None:
        """
        If event_id is provided, process that event.
        Otherwise claim one pending event and process it.
        """

        # 1) Decide which event to process
        if event_id is None:
            claimed = self.madrid_event_repo.claim_pending_events()
            if not claimed:
                self._logger.info("No pending Madrid events found")
                return
            event_id = claimed.event_id
            event_type = claimed.event_type
            serial_number = claimed.serial_number
        else:
            # If you have a "get by id" method, load it here:
            event = self.madrid_event_repo.get_event_by_id(event_id)
            if not event:
                raise ValueError(f"Madrid event not found for event_id={event_id}")
            event_type = event.event_type
            serial_number = event.serial_number

            # Optional: mark processing here if not already
            # self.madrid_event_repo.update_event_status(event_id, AssignmentStatus.MADRID_PROCESSING)

        self._logger.info("Processing Madrid event_id=%s", event_id)

        try:
            madrid_input = MadridEventInput(
                event_id=event_id,
                event_type=event_type,
                serial_number=serial_number,
            )

            # If processor is async, you’d use asyncio.run(...)
            self.processor.process_event(madrid_input)

            self.madrid_event_repo.finalize_event_status(
                event_id=event_id,
                status=AssignmentStatus.MADRID_PROCESSED,
                assignment_id=getattr(self.processor, "assignment_id", None),
                error_msg=None,
            )

            self._logger.info("Madrid event succeeded for event_id=%s", event_id)

        except Exception as ex:
            err = f"{type(ex).__name__}: {ex}\n{traceback.format_exc()}"
            self._logger.exception("Madrid event processing failed for event_id=%s", event_id)

            self.madrid_event_repo.finalize_event_status(
                event_id=event_id,
                status=AssignmentStatus.MADRID_FAIL,
                assignment_id=None,
                error_msg=err,
            )

            raise  # ✅ critical for AWS Batch retries / job failure visibility


