def save_correspondent(self, trademark_data, assignment_id):
    correspondence_info = getattr(trademark_data, "correspondence_info", None)
    if not correspondence_info or not getattr(correspondence_info, "ip_info", None):
        return None

    ip_info = correspondence_info.ip_info
    fk_address_id = None
    fk_individual_id = None

    mailing_addresses = getattr(getattr(ip_info, "contactAddress", None), "mailingAddresses", None)
    if mailing_addresses:
        mailing_address = mailing_addresses[0]
        saved_address = self.address_repo.upsert_address({
            "address_id": None,
            "address_line_1": getattr(mailing_address, "streetLineOne", None),
            "address_line_2": getattr(mailing_address, "streetLineTwo", None),
            "city": getattr(mailing_address, "city_name", None),
            "state": getattr(mailing_address, "state_name", None),
            "zip_code": getattr(mailing_address, "postcode", None),
            "country": getattr(mailing_address, "country_name", None),
            "lock_control_number": 1
        })
        if saved_address:
            fk_address_id = saved_address.get("address_id") if isinstance(saved_address, dict) else saved_address.address_id

    first_name = getattr(ip_info, "givenName", None)
    last_name = getattr(ip_info, "familyName", None)
    if not first_name and not last_name:
        name = getattr(ip_info, "name", None)
        if name and "," in name:
            parts = [p.strip() for p in name.split(",", 1)]
            first_name = parts[0]
            last_name = parts[1]

    if first_name or last_name:
        saved_individual = self.individual_repo.upsert_individual({
            "individual_id": None,
            "prefix": getattr(ip_info, "prefixName", None),
            "first_name": first_name,
            "middle_name": getattr(ip_info, "middleName", None),
            "last_name": last_name,
            "suffix": getattr(ip_info, "suffix", None),
            "lock_control_number": 1
        })
        if saved_individual:
            fk_individual_id = saved_individual.get("individual_id") if isinstance(saved_individual, dict) else saved_individual.individual_id

    correspondent = Correspondent(
        citizenship=None,
        citizenship_id=None,
        docket_number=getattr(correspondence_info, "docket_reference_no", None),
        fk_assignment_id=assignment_id,
        fk_address_id=fk_address_id,
        fk_individual_id=fk_individual_id
    )

    return self.correspondence_repo.save_correspondence_info(correspondent)
