def test_create_new_assignment_wraps_generic_exception_in_service_exception(
    service, mock_assignment_repo, mock_stnd_status_repo
):
    request_dto = {
        "formType": AssignmentType.PATENT.value[1],
        "name": "Test",
        "conveyanceTypeId": None,
        "isMultiAssignment": False,
        "multiAssignmentOrderNumber": None,
    }

    mock_stnd_status_repo.get_standard_status.side_effect = Exception("unexpected")

    with pytest.raises(ServiceException) as exc_info:
        service.create_new_assignment(request_dto, commit_flag=True)

    assert "Error occurred while Updating Assignment" in str(exc_info.value)