from datetime import datetime
from typing import Any, Dict, List, Optional


class ReceivingPartyPayloadMapper:
    @staticmethod
    def generate_payloads(
        owners: List[Any],
        assignment_id: int,
        form_type: str = "TRADEMARK",
    ) -> List[Dict[str, Any]]:
        payloads: List[Dict[str, Any]] = []

        for owner in owners or []:
            payload = ReceivingPartyPayloadMapper._map_owner(
                owner=owner,
                assignment_id=assignment_id,
                form_type=form_type,
            )
            if payload:
                payloads.append(payload)

        return payloads

    @staticmethod
    def _map_owner(
        owner: Any,
        assignment_id: int,
        form_type: str,
    ) -> Optional[Dict[str, Any]]:
        ip_info = ReceivingPartyPayloadMapper._get_value(owner, "ip_info", "ipInfo")
        if not ip_info:
            return None

        party_code = ReceivingPartyPayloadMapper._get_value(ip_info, "party_code", "partyCode")
        legal_entity = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(ip_info, "legal_entity", "legalEntity")
        )

        full_name = ReceivingPartyPayloadMapper._get_value(ip_info, "name")
        given_name = ReceivingPartyPayloadMapper._get_value(ip_info, "given_name", "givenName")
        family_name = ReceivingPartyPayloadMapper._get_value(ip_info, "family_name", "familyName")
        middle_name = ReceivingPartyPayloadMapper._get_value(ip_info, "middle_name", "middleName")
        prefix_name = ReceivingPartyPayloadMapper._get_value(ip_info, "prefix_name", "prefixName")
        suffix = ReceivingPartyPayloadMapper._get_value(ip_info, "suffix")

        first_name, last_name = ReceivingPartyPayloadMapper._derive_names(
            given_name=given_name,
            family_name=family_name,
            full_name=full_name,
        )

        citizenship_obj = ReceivingPartyPayloadMapper._get_value(ip_info, "citizenship")
        citizenship_id = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                citizenship_obj,
                "country_id",
                "countryId",
                "country_code",
                "countryCode",
            )
        )
        citizenship = ReceivingPartyPayloadMapper._get_value(
            citizenship_obj,
            "country_name",
            "countryName",
        )

        citizenship_state_id = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                citizenship_obj,
                "state_id",
                "stateId",
                "state_geo_code",
                "stateGeoCode",
            )
        )
        citizenship_state = ReceivingPartyPayloadMapper._get_value(
            citizenship_obj,
            "geographic_region_name",
            "geographicRegionName",
            "state_name",
            "stateName",
            "state_geo_code",
            "stateGeoCode",
        )

        if citizenship_id is None:
            raise ValueError("citizenshipId missing from Madrid input")

        if citizenship_state_id is None:
            raise ValueError("citizenshipStateId missing from Madrid input")

        if not citizenship:
            raise ValueError("citizenship missing from Madrid input")

        if not citizenship_state:
            raise ValueError("citizenshipState missing from Madrid input")

        email = ReceivingPartyPayloadMapper._get_email(ip_info)
        if not email:
            raise ValueError("receivingEmail missing from Madrid input")

        address_info = ReceivingPartyPayloadMapper._build_address_info(
            ip_info=ip_info,
        )

        payload: Dict[str, Any] = {
            "assignmentId": assignment_id,
            "formType": form_type,
            "receivingType": "INDIVIDUAL" if party_code == "I" else "ENTITY",
            "receivingEmail": email,
            "citizenshipId": citizenship_id,
            "citizenship": citizenship,
            "citizenshipStateId": citizenship_state_id,
            "citizenshipState": citizenship_state,
            "executionDate": datetime.utcnow().strftime("%Y-%m-%d"),
            "addressInfo": address_info,
        }

        if party_code == "I":
            payload["individual"] = {
                "individualId": None,
                "prefix": prefix_name,
                "firstName": first_name or "Unknown",
                "middleName": middle_name,
                "lastName": last_name or "Unknown",
                "suffix": suffix,
                "lockControlNumber": 1,
            }
        else:
            payload["entity"] = {
                "entityId": None,
                "entityName": full_name or "Unknown Entity",
                "legalEntityTypeId": legal_entity,
                "lockControlNumber": 1,
            }

        return payload

    @staticmethod
    def _build_address_info(ip_info: Any) -> Dict[str, Any]:
        contact_address = ReceivingPartyPayloadMapper._get_value(
            ip_info, "contact_address", "contactAddress"
        )
        mailing_addresses = ReceivingPartyPayloadMapper._get_value(
            contact_address, "mailing_addresses", "mailingAddresses"
        ) or []

        first_mailing = mailing_addresses[0] if mailing_addresses else None
        if not first_mailing:
            raise ValueError("mailing address missing from Madrid input")

        address_id = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                first_mailing, "address_id", "addressId"
            ),
            allow_none=True,
        )

        address_line_one = ReceivingPartyPayloadMapper._get_value(
            first_mailing,
            "street_address_line_text",
            "streetAddressLineText",
            "address_line_one",
            "addressLineOne",
        )
        address_line_two = ReceivingPartyPayloadMapper._get_value(
            first_mailing,
            "free_format_address",
            "freeFormatAddress",
            "address_line_two",
            "addressLineTwo",
        )

        city = ReceivingPartyPayloadMapper._get_value(
            first_mailing, "city_name", "cityName"
        )

        state_id = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                first_mailing,
                "state_id",
                "stateId",
                "state_geo_code",
                "stateGeoCode",
            )
        )
        state = ReceivingPartyPayloadMapper._get_value(
            first_mailing,
            "state_name",
            "stateName",
            "state_geo_code",
            "stateGeoCode",
            "geographic_region_name",
            "geographicRegionName",
        )

        zip_code = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                first_mailing,
                "postal_code",
                "postalCode",
                "zip_code",
                "zipCode",
            )
        )

        country_id = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._get_value(
                first_mailing,
                "country_id",
                "countryId",
                "country_code",
                "countryCode",
            )
        )
        country = ReceivingPartyPayloadMapper._get_value(
            first_mailing,
            "country_name",
            "countryName",
        )

        if not address_line_one:
            raise ValueError("addressLineOne missing from Madrid input")

        if not city:
            raise ValueError("city missing from Madrid input")

        if state_id is None:
            raise ValueError("stateId missing from Madrid input")

        if not state:
            raise ValueError("state missing from Madrid input")

        if zip_code is None:
            raise ValueError("zipCode missing from Madrid input")

        if country_id is None:
            raise ValueError("countryId missing from Madrid input")

        if not country:
            raise ValueError("country missing from Madrid input")

        return {
            "addressId": address_id,
            "attention": "Test Receiver",
            "addressLineOne": address_line_one,
            "addressLineTwo": address_line_two,
            "city": city,
            "stateId": state_id,
            "state": state,
            "zipCode": zip_code,
            "countryId": country_id,
            "country": country,
            "lockControlNumber": 1,
        }

    @staticmethod
    def _get_email(ip_info: Any) -> Optional[str]:
        contact_address = ReceivingPartyPayloadMapper._get_value(
            ip_info, "contact_address", "contactAddress"
        )
        electronic_addresses = ReceivingPartyPayloadMapper._get_value(
            contact_address, "electronic_address", "electronicAddress"
        ) or []

        first_email = electronic_addresses[0] if electronic_addresses else None

        return ReceivingPartyPayloadMapper._get_value(
            first_email,
            "electronic_address_text",
            "electronicAddressText",
            "email",
        )

    @staticmethod
    def _derive_names(
        given_name: Optional[str],
        family_name: Optional[str],
        full_name: Optional[str],
    ) -> tuple[Optional[str], Optional[str]]:
        if given_name:
            return given_name, family_name

        if not full_name:
            return None, None

        if "," in full_name:
            parts = [p.strip() for p in full_name.split(",") if p.strip()]
            if len(parts) >= 2:
                return parts[1], parts[0]

        parts = [p.strip() for p in full_name.split() if p.strip()]
        if len(parts) >= 2:
            return " ".join(parts[:-1]), parts[-1]

        return full_name, full_name

    @staticmethod
    def _safe_int(value: Any, default: Optional[int] = None, allow_none: bool = False) -> Optional[int]:
        if value is None and allow_none:
            return None
        try:
            return int(str(value).strip())
        except (TypeError, ValueError):
            return default

    @staticmethod
    def _get_value(obj: Any, *names: str) -> Any:
        if obj is None:
            return None

        for name in names:
            if isinstance(obj, dict) and name in obj:
                return obj.get(name)

            if hasattr(obj, name):
                return getattr(obj, name)

            unknown_fields = getattr(obj, "unknown_fields", None)
            if isinstance(unknown_fields, dict) and name in unknown_fields:
                return unknown_fields.get(name)

        return None