def test_create_new_assignment_hash_name_triggers_second_save(
    service, mock_assignment_repo, mock_stnd_status_repo, mock_stnd_conveyance_repo, mock_status
):
    request_dto = {
        "formType": AssignmentType.PATENT.value[1],
        "name": "#",
        "conveyanceTypeId": None,
        "isMultiAssignment": False,
        "multiAssignmentOrderNumber": None,
    }

    first_saved_assignment = MagicMock()
    first_saved_assignment.assignment_id = 555

    second_saved_assignment = MagicMock()
    second_saved_assignment.assignment_id = 555
    second_saved_assignment.assignment_dto.return_value = {"assignmentId": 555}

    mock_stnd_status_repo.get_standard_status.return_value = mock_status
    mock_assignment_repo.save_assignment.side_effect = [
        first_saved_assignment,
        second_saved_assignment,
    ]

    result = service.create_new_assignment(request_dto, commit_flag=True)

    assert mock_assignment_repo.save_assignment.call_count == 2

    first_call_assignment = mock_assignment_repo.save_assignment.call_args_list[0][0][0]
    second_call_assignment = mock_assignment_repo.save_assignment.call_args_list[1][0][0]

    assert first_call_assignment.name == "#"
    assert second_call_assignment.name == 555
    assert result == {"assignmentId": 555}


