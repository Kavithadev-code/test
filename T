import pytest
from unittest.mock import MagicMock
from sqlalchemy.exc import SQLAlchemyError
from sqlalchemy.orm import Session

from src.repositories.assignment.correspondence_repository import CorrespondenceRepository
from src.exceptions.database_exception import DatabaseException


@pytest.fixture
def mock_db_session():
    return MagicMock(spec=Session)


@pytest.fixture
def mock_repo(mock_db_session):
    return CorrespondenceRepository(mock_db_session)


@pytest.fixture
def mock_correspondence():
    obj = MagicMock()
    obj.correspondent_id = 101
    return obj


def test_get_correspondence_info_by_correspondent_id_found(
    mock_repo, mock_db_session, mock_correspondence
):
    mock_query = MagicMock()
    mock_query.get.return_value = mock_correspondence
    mock_db_session.query.return_value = mock_query

    result = mock_repo.get_correspondence_info_by_correspondent_id(101)

    mock_db_session.query.assert_called_once()
    mock_query.get.assert_called_once_with(101)
    assert result == mock_correspondence


def test_get_correspondence_info_by_correspondent_id_not_found(
    mock_repo, mock_db_session
):
    mock_query = MagicMock()
    mock_query.get.return_value = None
    mock_db_session.query.return_value = mock_query

    result = mock_repo.get_correspondence_info_by_correspondent_id(101)

    mock_db_session.query.assert_called_once()
    mock_query.get.assert_called_once_with(101)
    assert result is None


def test_get_correspondence_info_by_correspondent_id_exception(
    mock_repo, mock_db_session
):
    mock_db_session.query.side_effect = Exception("db error")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.get_correspondence_info_by_correspondent_id(101)

    assert "Unable to get Correspondent Info" in str(exc_info.value)


