def transform_properties_to_app_numbers(response: dict) -> dict:
    """
    Replace properties with list of applicationNumbers inside response['data']
    """

    data = response.get("data", [])

    for item in data:
        properties = item.get("properties", [])

        item["properties"] = [
            prop.get("applicationNumber")
            for prop in properties
            if isinstance(prop, dict) and prop.get("applicationNumber")
        ]

    return response