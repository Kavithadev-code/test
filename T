import pytest
from unittest.mock import MagicMock
from sqlalchemy.exc import SQLAlchemyError

from src.repositories.assignment.assignment_repository import AssignmentRepository
from src.exceptions.database_exception import DatabaseException


@pytest.fixture
def mock_session():
    return MagicMock()


@pytest.fixture
def repository(mock_session):
    return AssignmentRepository(mock_session)


def test_save_assignment_new_with_commit_true(repository, mock_session):
    assignment = MagicMock()
    assignment.assignment_id = None

    result = repository.save_assignment(assignment, commit_flag=True)

    mock_session.add.assert_called_once_with(assignment)
    mock_session.commit.assert_called_once()
    mock_session.flush.assert_not_called()
    mock_session.refresh.assert_not_called()
    assert result == assignment


def test_save_assignment_new_with_commit_false(repository, mock_session):
    assignment = MagicMock()
    assignment.assignment_id = None

    result = repository.save_assignment(assignment, commit_flag=False)

    mock_session.add.assert_called_once_with(assignment)
    mock_session.commit.assert_not_called()
    mock_session.flush.assert_called_once()
    mock_session.refresh.assert_called_once_with(assignment)
    assert result == assignment


def test_save_assignment_existing_assignment(repository, mock_session):
    assignment = MagicMock()
    assignment.assignment_id = 100

    result = repository.save_assignment(assignment, commit_flag=True)

    mock_session.add.assert_not_called()
    mock_session.commit.assert_called_once()
    mock_session.flush.assert_not_called()
    mock_session.refresh.assert_not_called()
    assert result == assignment


def test_save_assignment_sqlalchemy_error_on_add(repository, mock_session):
    assignment = MagicMock()
    assignment.assignment_id = None
    mock_session.add.side_effect = SQLAlchemyError("db failure")

    with pytest.raises(DatabaseException) as exc_info:
        repository.save_assignment(assignment, commit_flag=True)

    mock_session.rollback.assert_called_once()
    assert "Error saving Assignment details" in str(exc_info.value)


