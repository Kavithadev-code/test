import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError
from sqlalchemy.orm import Session

from src.repositories.assignment.individual_repository import IndividualRepository
from src.exceptions.database_exception import DatabaseException


INDIVIDUAL_INPUT_DATA = {
    "individual_id": 10,
    "prefix": "Mr",
    "first_name": "John",
    "middle_name": "A",
    "last_name": "Doe",
    "suffix": "Jr"
}


@pytest.fixture
def mock_db_session():
    return MagicMock(spec=Session)


@pytest.fixture
def mock_repo(mock_db_session):
    return IndividualRepository(mock_db_session)


@pytest.fixture
def mock_individual():
    obj = MagicMock()
    obj.individual_id = 10
    return obj


def test_save_individual_info_new_commit_true(mock_repo, mock_db_session):
    individual = MagicMock()
    individual.individual_id = None

    result = mock_repo.save_individual_info(individual, commit_flag=True)

    mock_db_session.add.assert_called_once_with(individual)
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == individual


def test_save_individual_info_new_commit_false(mock_repo, mock_db_session):
    individual = MagicMock()
    individual.individual_id = None

    result = mock_repo.save_individual_info(individual, commit_flag=False)

    mock_db_session.add.assert_called_once_with(individual)
    mock_db_session.commit.assert_not_called()
    mock_db_session.flush.assert_called_once()
    mock_db_session.refresh.assert_called_once_with(individual)
    assert result == individual


def test_save_individual_info_existing_individual(mock_repo, mock_db_session):
    individual = MagicMock()
    individual.individual_id = 25

    result = mock_repo.save_individual_info(individual, commit_flag=True)

    mock_db_session.add.assert_not_called()
    mock_db_session.commit.assert_not_called()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == individual


def test_save_individual_info_sqlalchemy_error_on_add(mock_repo, mock_db_session):
    individual = MagicMock()
    individual.individual_id = None
    mock_db_session.add.side_effect = SQLAlchemyError("db failure")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.save_individual_info(individual, commit_flag=True)

    mock_db_session.rollback.assert_called_once()
    assert "Error saving Individual Name details" in str(exc_info.value)


