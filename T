from unittest.mock import patch

def test_validate_trademark_properties_success(mock_client):
    data = {
        "assignmentId": 16592,
        "searchBy": "serialNumber",
        "searchList": ["74195633", "74195634"]
    }

    # Patch ONLY the service used inside the route
    with patch("src.routes.assignments.trademark_properties_route.TrademarkPropertiesService") as mock_service_cls:
        mock_service = mock_service_cls.return_value
        mock_service.validate_trademark_properties.return_value = True

        response = mock_client.post(
            "/assignment/validate/trademark_properties",
            json=data
        )

    assert response.status_code == 200
    assert response.headers["Content-Type"].startswith("application/json")