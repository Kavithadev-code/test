import pytest
from unittest.mock import MagicMock, patch

from src.repositories.assignment.receiving_party_repository import ReceivingPartyRepository


SAVE_INPUT_DATA = {
    "receiving_party_id": 10,
    "name": "ABC Corp"
}


@pytest.fixture
def mock_db_session():
    return MagicMock()


@pytest.fixture
def mock_repo(mock_db_session):
    return ReceivingPartyRepository(mock_db_session)


@pytest.fixture
def mock_receiving_party():
    obj = MagicMock()
    obj.to_dict.return_value = {
        "receiving_party_id": 10,
        "name": "ABC Corp"
    }
    return obj


def test_save_receiving_parties_existing_commit_true(
    mock_repo, mock_db_session, mock_receiving_party
):
    input_data = SAVE_INPUT_DATA.copy()
    input_data["receiving_party_id"] = 10

    mock_filter = MagicMock()
    mock_filter.first.return_value = mock_receiving_party
    mock_db_session.query.return_value.filter.return_value = mock_filter

    result = mock_repo.save_receiving_parties(
        input_data,
        type_id=1,
        address_id=100,
        domestic_individual_id=200,
        domestic_address_info_id=300,
        commit_flag=True,
    )

    mock_db_session.query.assert_called_once()
    mock_db_session.query.return_value.filter.assert_called_once()
    mock_filter.first.assert_called_once()
    mock_receiving_party.set_receiving_party.assert_called_once_with(
        input_data, 1, 100, 200, 300
    )
    mock_db_session.add.assert_not_called()
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == mock_receiving_party.to_dict.return_value


