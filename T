def test_create_new_assignment_patent_success(
    service, mock_assignment_repo, mock_stnd_status_repo, mock_stnd_conveyance_repo, mock_status
):
    request_dto = {
        "formType": AssignmentType.PATENT.value[1],
        "name": "Test Assignment",
        "conveyanceTypeId": 12,
        "isMultiAssignment": True,
        "multiAssignmentOrderNumber": 5,
    }

    saved_assignment = MagicMock()
    saved_assignment.assignment_id = 101
    saved_assignment.assignment_dto.return_value = {"assignmentId": 101}

    mock_stnd_status_repo.get_standard_status.return_value = mock_status
    mock_stnd_conveyance_repo.get_standard_conveyance_id_by_conveyance_code.return_value = 99
    mock_assignment_repo.save_assignment.return_value = saved_assignment

    result = service.create_new_assignment(request_dto, commit_flag=True)

    mock_stnd_status_repo.get_standard_status.assert_called_once_with(
        AssignmentStatus.SAVED.value
    )
    mock_stnd_conveyance_repo.get_standard_conveyance_id_by_conveyance_code.assert_called_once_with(12)
    mock_assignment_repo.save_assignment.assert_called_once()
    saved_obj = mock_assignment_repo.save_assignment.call_args[0][0]

    assert saved_obj.fk_assignment_type_id == AssignmentType.PATENT.value[0]
    assert saved_obj.name == "Test Assignment"
    assert saved_obj.fk_status_id == 8
    assert saved_obj.fk_conveyance_type_id == 99
    assert saved_obj.is_multi_assignment is True
    assert saved_obj.multi_assignment_order_number == 5
    assert result == {"assignmentId": 101}


def test_create_new_assignment_trademark_without_conveyance_success(
    service, mock_assignment_repo, mock_stnd_status_repo, mock_stnd_conveyance_repo, mock_status
):
    request_dto = {
        "formType": "something_else",
        "name": "Trademark Assignment",
        "conveyanceTypeId": None,
        "isMultiAssignment": False,
        "multiAssignmentOrderNumber": None,
    }

    saved_assignment = MagicMock()
    saved_assignment.assignment_id = 102
    saved_assignment.assignment_dto.return_value = {"assignmentId": 102}

    mock_stnd_status_repo.get_standard_status.return_value = mock_status
    mock_assignment_repo.save_assignment.return_value = saved_assignment

    result = service.create_new_assignment(request_dto, commit_flag=True)

    mock_stnd_conveyance_repo.get_standard_conveyance_id_by_conveyance_code.assert_not_called()
    mock_assignment_repo.save_assignment.assert_called_once()
