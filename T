import json
import requests


def process_event(self, madridEvent):
    receiving_parties = self.sort_owners_by_party_role_seq_no(trademark_data.owners)
    conveying_parties = self.sort_owners_by_party_role_seq_no(trademark_data.owners)

    status = 31
    fk_assignment_type_id = AssignmentType.TRADEMARK.value[0]

    assignment = Assignment()
    assignment.fk_status_id = status
    assignment.fk_assignment_type_id = fk_assignment_type_id
    assignment.name = assignment.name or "temp"

    payload_input = {
        "client_ip": "151.207.40.24",
        "electronic_signature": "Y",
        "form_type": "TRADEMARK",
        "is_multi_assignment": False,
        "lock_control_number": 1,
        "name": "TM Assignment 1894483",
        "conveying_parties": conveying_parties,
        "receiving_parties": receiving_parties,
    }

    payload = AssignmentPayloadMapper.generate_payload(payload_input)

    print("FINAL PAYLOAD:")
    print(json.dumps(payload, indent=2, default=str))

    url = "https://assignmentcenter-dev2-internal.ipas.awslab.uspto.gov/ipas/process/api/v2/create_assignment"

    response = requests.post(
        url=url,
        json=payload,
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
        verify=False,
        timeout=60,
    )

    print("status =", response.status_code)
    print("reason =", response.reason)
    print("response_text =", response.text)

    response.raise_for_status()
