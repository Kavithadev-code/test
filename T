class CorrespondencePayloadMapper:

    @staticmethod
    def from_receiving_payload(receiving_payload: dict, assignment_id: int):
        individual = receiving_payload.get("individual", {})
        address = receiving_payload.get("addressInfo", {})

        payload = {
            "assignmentId": assignment_id,
            "correspondentInfo": {
                "name": {
                    "firstName": individual.get("firstName"),
                    "lastName": individual.get("lastName"),
                    "middleName": individual.get("middleName"),
                    "prefix": individual.get("prefix"),
                    "suffix": individual.get("suffix"),
                },
                "addressInfo": {
                    "addressLineOne": address.get("addressLineOne"),
                    "addressLineTwo": address.get("addressLineTwo"),
                    "attention": address.get("attention"),
                    "city": address.get("city"),
                    "state": address.get("state"),
                    "country": address.get("country"),
                    "countryId": address.get("countryId"),
                    "zipCode": address.get("zipCode"),
                },
                "phones": receiving_payload.get("phones", []),
                "emails": receiving_payload.get("emails", [])
            }
        }

        return payload