from typing import Any, Dict, List, Optional


class AssignmentPayloadMapper:
    @staticmethod
    def generate_payload(data: Dict[str, Any]) -> Dict[str, Any]:
        return {
            "clientIp": data.get("client_ip"),
            "electronicSignature": data.get("electronic_signature"),
            "formType": data.get("form_type"),
            "isMultiAssignment": data.get("is_multi_assignment", False),
            "lockControlNumber": data.get("lock_control_number", 1),
            "name": data.get("name"),
            "conveyingInfoList": [
                AssignmentPayloadMapper._map_party(party)
                for party in data.get("conveying_parties", [])
            ],
            "receivingInfoList": [
                AssignmentPayloadMapper._map_party(party)
                for party in data.get("receiving_parties", [])
            ],
        }

    @staticmethod
    def _map_party(party: Any) -> Dict[str, Any]:
        ip_info = AssignmentPayloadMapper._safe_get(party, "ip_info") or {}
        citizenship = AssignmentPayloadMapper._safe_get(ip_info, "citizenship") or {}
        contact_address = AssignmentPayloadMapper._safe_get(ip_info, "contact_address") or {}

        mailing_addresses = (
            AssignmentPayloadMapper._safe_get(contact_address, "mailing_addresses") or []
        )
        electronic_addresses = (
            AssignmentPayloadMapper._safe_get(contact_address, "electronic_address") or []
        )

        first_mailing = mailing_addresses[0] if mailing_addresses else {}
        first_email = electronic_addresses[0] if electronic_addresses else {}

        return {
            "ownerSequenceNo": AssignmentPayloadMapper._safe_get(party, "owner_sequence_no"),
            "partyRoleSeqNo": AssignmentPayloadMapper._safe_get(party, "party_role_seq_no"),
            "tmPartyRoleId": AssignmentPayloadMapper._safe_get(party, "tm_party_role_id"),
            "ownerTypeCd": AssignmentPayloadMapper._safe_get(party, "owner_type_cd"),
            "id": AssignmentPayloadMapper._safe_get(ip_info, "id"),
            "name": AssignmentPayloadMapper._safe_get(ip_info, "name"),
            "partyCode": AssignmentPayloadMapper._safe_get(ip_info, "party_code"),
            "legalEntity": AssignmentPayloadMapper._safe_get(ip_info, "legal_entity"),
            "givenName": AssignmentPayloadMapper._safe_get(ip_info, "given_name"),
            "familyName": AssignmentPayloadMapper._safe_get(ip_info, "family_name"),
            "middleName": AssignmentPayloadMapper._safe_get(ip_info, "middle_name"),
            "prefixName": AssignmentPayloadMapper._safe_get(ip_info, "prefix_name"),
            "suffix": AssignmentPayloadMapper._safe_get(ip_info, "suffix"),
            "assumedName": AssignmentPayloadMapper._map_assumed_name(
                AssignmentPayloadMapper._safe_get(ip_info, "assumed_name")
            ),
            "countryCode": AssignmentPayloadMapper._safe_get(citizenship, "country_code"),
            "countryName": AssignmentPayloadMapper._safe_get(citizenship, "country_name"),
            "mailingAddress": AssignmentPayloadMapper._map_mailing_address(first_mailing),
            "electronicAddress": AssignmentPayloadMapper._map_electronic_address(first_email),
        }

    @staticmethod
    def _map_assumed_name(assumed_name: Any) -> Optional[Dict[str, Any]]:
        if not assumed_name:
            return None

        return {
            "assumedNameTypeCd": AssignmentPayloadMapper._safe_get(assumed_name, "assumed_name_type_cd"),
            "interestPartyAssumedName": AssignmentPayloadMapper._safe_get(
                assumed_name, "interest_party_assumed_name"
            ),
        }

    @staticmethod
    def _map_mailing_address(address: Any) -> Optional[Dict[str, Any]]:
        if not address:
            return None

        return {
            "globalIdentifier": AssignmentPayloadMapper._safe_get(address, "global_identifier"),
            "addressName": AssignmentPayloadMapper._safe_get(address, "address_name"),
            "freeFormatAddress": AssignmentPayloadMapper._safe_get(address, "free_format_address"),
            "streetAddressLineText": AssignmentPayloadMapper._safe_get(address, "street_address_line_text"),
            "cityName": AssignmentPayloadMapper._safe_get(address, "city_name"),
            "geographicRegionName": AssignmentPayloadMapper._safe_get(address, "geographic_region_name"),
            "stateGeoCode": AssignmentPayloadMapper._safe_get(address, "state_geo_code"),
            "countryCode": AssignmentPayloadMapper._safe_get(address, "country_code"),
            "countryName": AssignmentPayloadMapper._safe_get(address, "country_name"),
            "postalCode": AssignmentPayloadMapper._safe_get(address, "postal_code"),
        }

    @staticmethod
    def _map_electronic_address(address: Any) -> Optional[Dict[str, Any]]:
        if not address:
            return None

        return {
            "electronicTypeCode": AssignmentPayloadMapper._safe_get(address, "electronic_type_code"),
            "electronicAddressText": AssignmentPayloadMapper._safe_get(address, "electronic_address_text"),
        }

    @staticmethod
    def _safe_get(obj: Any, key: str, default: Any = None) -> Any:
        if obj is None:
            return default

        if isinstance(obj, dict):
            return obj.get(key, default)

        return getattr(obj, key, default)
