def test_upsert_entity_update_existing(mock_repo, mock_db_session, mock_entity):
    input_data = ENTITY_INPUT_DATA.copy()
    input_data["entity_id"] = 10

    mock_query = MagicMock()
    mock_query.get.return_value = mock_entity
    mock_db_session.query.return_value = mock_query

    result = mock_repo.upsert_entity(input_data, commit_flag=True)

    mock_db_session.query.assert_called_once()
    mock_query.get.assert_called_once_with(10)
    mock_entity.set_entity.assert_called_once_with(input_data)
    mock_db_session.commit.assert_called_once()
    assert result == mock_entity


def test_upsert_entity_create_new(mock_repo):
    input_data = ENTITY_INPUT_DATA.copy()
    input_data["entity_id"] = 0

    new_entity = MagicMock()

    with patch(
        "src.repositories.assignment.entity_repository.Entity"
    ) as mock_entity_class, patch.object(
        mock_repo, "save_entity_info", return_value=new_entity
    ) as mock_save:
        mock_entity_class.from_dict.return_value = new_entity

        result = mock_repo.upsert_entity(input_data, commit_flag=True)

    mock_entity_class.from_dict.assert_called_once_with(input_data)
    mock_save.assert_called_once_with(new_entity, True)
    assert result == new_entity


