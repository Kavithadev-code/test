for prop in all_properties:

    if not isinstance(prop, dict):
        continue

    property_id = prop.get("property_id")

    if property_id is None:
        continue

    matched = False

    # Check existing OPSG records
    for opsg_record in opsg_results:

        if opsg_record.get("applicationNumberText") == property_id:

            # Update existing record
            opsg_record["property_sequence_number"] = prop.get(
                "property_sequence_number"
            )

            matched = True
            break

    # If no matching OPSG record found, append new one
    if not matched:

        opsg_results.append({
            "applicationNumberText": property_id,
            "property_sequence_number": prop.get("property_sequence_number")
        })