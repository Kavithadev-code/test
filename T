from datetime import date, datetime

def get_date_mm_dd_yyyy(value):
    if not value:
        return ""

    value = str(value).strip()

    # timestamp like 348814800
    if value.isdigit() and len(value) > 8:
        value = date.fromtimestamp(float(value)).strftime("%Y%m%d")

    # YYYYMMDD only
    if value.isdigit() and len(value) == 8:
        return datetime.strptime(value, "%Y%m%d").date().strftime(config.date_mm_dd_yyyy)

    return ""