def transform_properties_to_app_numbers(response: dict) -> dict:
    """
    Replace response['data']['properties'] with only applicationNumber values.
    Keep everything else unchanged.
    """
    data = response.get("data", {})

    if not isinstance(data, dict):
        return response

    properties = data.get("properties", [])

    if not isinstance(properties, list):
        return response

    data["properties"] = [
        prop.get("applicationNumber")
        for prop in properties
        if isinstance(prop, dict) and prop.get("applicationNumber")
    ]

    return respect 