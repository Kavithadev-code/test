import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError

from src.repositories.assignment.address_repository import AddressRepository
from src.exceptions.database_exception import DatabaseException


@pytest.fixture
def mock_session():
    return MagicMock()


@pytest.fixture
def repository(mock_session):
    return AddressRepository(mock_session)


def test_save_address_info_new_address(repository, mock_session):
    address = MagicMock()
    address.address_id = None

    result = repository.save_address_info(address)

    mock_session.add.assert_called_once_with(address)
    mock_session.commit.assert_called_once()
    assert result == address


def test_save_address_info_existing_address(repository, mock_session):
    address = MagicMock()
    address.address_id = 101

    result = repository.save_address_info(address)

    mock_session.add.assert_not_called()
    mock_session.commit.assert_called_once()
    assert result == address


def test_save_address_info_sqlalchemy_error(repository, mock_session):
    address = MagicMock()
    address.address_id = None
    mock_session.add.side_effect = SQLAlchemyError("db error")

    with pytest.raises(DatabaseException) as exc_info:
        repository.save_address_info(address)

    mock_session.rollback.assert_called_once()
    assert "Error saving Address details" in str(exc_info.value)


def test_get_address_info_by_address_id_found(repository, mock_session):
    address_id = 123
    mock_address = MagicMock()

    mock_query = MagicMock()
    mock_query.get.return_value = mock_address
    mock_session.query.return_value = mock_query

