def test_save_correspondence_info_new_commit_true(
    mock_repo, mock_db_session
):
    correspondence = MagicMock()
    correspondence.correspondent_id = None

    result = mock_repo.save_correspondence_info(
        correspondence, commit_flag=True
    )

    mock_db_session.add.assert_called_once_with(correspondence)
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    assert result == correspondence


