import pytest
import requests

from service.madrid.trademark_client import TrademarkClient, TrademarkApiError


class DummyResponse:
    def __init__(self, status_code=200, content=b"", reason="OK"):
        self.status_code = status_code
        self.content = content
        self.reason = reason


class TestTrademarkClient:

    @pytest.fixture
    def client(self):
        return TrademarkClient(timeout_seconds=150)

    @pytest.fixture
    def mock_env_config(self, monkeypatch):
        class DummyConfig:
            CURRENT_ENV_CONFIG = {
                "TRADEMARK_URL": "https://example.com/trademark/",
                "TRADEMARK_URL_SERIAL_NO": "/serial/"
            }

        monkeypatch.setattr("service.madrid.trademark_client.config", DummyConfig)
        monkeypatch.setattr("service.madrid.trademark_client.CERT_PATH", "/tmp/test-cert.pem")
        return DummyConfig

    def test_fetch_by_serial_success(self, client, mock_env_config, monkeypatch):
        response = DummyResponse(
            status_code=200,
            content=b'{"serial_number":"12345","status":"ok"}',
            reason="OK"
        )

        captured = {}

        def mock_get(url, verify, timeout):
            captured["url"] = url
            captured["verify"] = verify
            captured["timeout"] = timeout
            return response

        monkeypatch.setattr("service.madrid.trademark_client.requests.get", mock_get)

        result = client.fetch_by_serial("12345")

        assert result == '{"serial_number":"12345","status":"ok"}'
        assert captured["url"] == "https://example.com/trademark//serial/12345"
        assert captured["verify"] == "/tmp/test-cert.pem"
        assert captured["timeout"] == 150

    def test_fetch_by_serial_uses_custom_timeout(self, mock_env_config, monkeypatch):
        client = TrademarkClient(timeout_seconds=30)

        response = DummyResponse(
            status_code=200,
            content=b'{"serial_number":"99999"}',
            reason="OK"
        )

        captured = {}

        def mock_get(url, verify, timeout):
            captured["timeout"] = timeout
            return response

        monkeypatch.setattr("service.madrid.trademark_client.requests.get", mock_get)

        result = client.fetch_by_serial("99999")

        assert result == '{"serial_number":"99999"}'
        assert captured["timeout"] == 30

    def test_fetch_by_serial_request_exception_raises_trademark_api_error(
        self, client, mock_env_config, monkeypatch
    ):
        def mock_get(url, verify, timeout):
            raise requests.RequestException("connection failed")

        monkeypatch.setattr("service.madrid.trademark_client.requests.get", mock_get)

        with pytest.raises(TrademarkApiError) as exc_info:
            client.fetch_by_serial("12345")

        assert "TRM request failed: connection failed" in str(exc_info.value)

    def test_fetch_by_serial_non_200_status_raises_trademark_api_error(
        self, client, mock_env_config, monkeypatch
    ):
        response = DummyResponse(
            status_code=500,
            content=b'{"error":"server error"}',
            reason="Internal Server Error"
        )

        def mock_get(url, verify, timeout):
            return response

        monkeypatch.setattr("service.madrid.trademark_client.requests.get", mock_get)

        with pytest.raises(TrademarkApiError) as exc_info:
            client.fetch_by_serial("12345")

        assert "TRM returned 500" in str(exc_info.value)
        assert "Internal Server Error" in str(exc_info.value)

    def test_fetch_by_serial_returns_decoded_utf8_string(
        self, client, mock_env_config, monkeypatch
    ):
        response = DummyResponse(
            status_code=200,
            content="hello trademark".encode("utf-8"),
            reason="OK"
        )

        def mock_get(url, verify, timeout):
            return response

        monkeypatch.setattr("service.madrid.trademark_client.requests.get", mock_get)

        result = client.fetch_by_serial("55555")

        assert result == "hello trademark"
        assert isinstance(result, str)
