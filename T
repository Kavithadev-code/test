from typing import Any, Dict


class AssignmentPayloadMapper:
    @staticmethod
    def generate_payload(data: Dict[str, Any]) -> Dict[str, Any]:
        payload = {
            "formType": data.get("form_type", "TRADEMARK"),
            "isMultiAssignment": bool(data.get("is_multi_assignment", False)),
            "multiAssignmentOrderNumber": data.get("multi_assignment_order_number"),
            "name": data.get("name"),
            "isResubmission": bool(data.get("is_resubmission", False)),
            "isReviewed": bool(data.get("is_reviewed", False)),
        }

        if not payload["isMultiAssignment"]:
            payload["multiAssignmentOrderNumber"] = None

        return payload



