class CorrespondencePayloadMapper:

    @staticmethod
    def from_receiving_response(first_receiving_response, assignment_id):
        """
        Build correspondence payload from receiving party response
        """

        # extract safely
        address = first_receiving_response.get("address", {}) or {}
        individual = first_receiving_response.get("individual", {}) or {}

        return {
            "assignmentId": assignment_id,
            "correspondentInfo": {
                "correspondentId": first_receiving_response.get("receiving_party_id"),

                "docketNumber": None,

                "name": {
                    "firstName": individual.get("first_name"),
                    "middleName": individual.get("middle_name"),
                    "lastName": individual.get("last_name"),
                    "prefix": individual.get("prefix"),
                    "suffix": individual.get("suffix")
                },

                "addressInfo": {
                    "addressLineOne": address.get("address_line1"),
                    "addressLineTwo": address.get("address_line2"),
                    "city": address.get("city"),
                    "state": address.get("state"),
                    "stateId": address.get("state_id"),
                    "country": address.get("country"),
                    "countryId": address.get("country_id"),
                    "zipCode": address.get("zip_code"),
                    "attention": address.get("attention")
                },

                "phones": [
                    {
                        "type": "PRIMARY",
                        "phoneNumber": "1234567890",
                        "extension": None
                    }
                ],

                "emails": [
                    {
                        "email": "test@example.com",
                        "isPrimaryEmail": True
                    }
                ]
            }
        }