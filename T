def test_upsert_individual_update_existing(mock_repo, mock_db_session, mock_individual):
    input_data = INDIVIDUAL_INPUT_DATA.copy()
    input_data["individual_id"] = 10

    mock_query = MagicMock()
    mock_query.get.return_value = mock_individual
    mock_db_session.query.return_value = mock_query

    result = mock_repo.upsert_individual(input_data, commit_flag=True)

    mock_db_session.query.assert_called_once()
    mock_query.get.assert_called_once_with(10)
    mock_individual.set_individual.assert_called_once_with(input_data)
    mock_db_session.commit.assert_called_once()
    assert result == mock_individual


def test_upsert_individual_create_new(mock_repo):
