def test_save_assignment_details_success(
    service,
    mock_session,
    mock_assignment_service,
    mock_trademark_service,
    mock_receiving_party_service,
    mock_conveying_party_service,
    mock_correspondence_service,
    validated_request,
):
    mock_assignment_service.create_new_assignment.return_value = {"assignmentId": 101}
    mock_trademark_service.save_properties.return_value = [{"trademark_property_id": 1}]
    mock_receiving_party_service.save_receiving_parties.return_value = {"receiving_party_id": 11}
    mock_correspondence_service.save_assignment_correspondence_info.return_value = {"correspondent_id": 21}
    mock_conveying_party_service.save_conveying_parties.return_value = {"conveying_party_id": 31}

    service.save_assignment_details(validated_request)

    mock_assignment_service.create_new_assignment.assert_called_once_with(
        validated_request["assignment_payload"], False
    )

    mock_trademark_service.save_properties.assert_called_once_with(
        validated_request["trademark_property_payload"]["property_list"],
        101,
        False,
    )

    receiving_call_payload = validated_request["receiving_payloads"][0]
    assert receiving_call_payload["assignment_id"] == 101
    mock_receiving_party_service.save_receiving_parties.assert_called_once_with(
        receiving_call_payload, False
    )

    correspondence_payload = validated_request["correspondence_payload"]
    assert correspondence_payload["assignmentId"] == 101
    mock_correspondence_service.save_assignment_correspondence_info.assert_called_once_with(
        correspondence_payload, False
    )

    conveying_call_payload = validated_request["conveying_payloads"][0]
    assert conveying_call_payload["assignment_id"] == 101
    mock_conveying_party_service.save_conveying_parties.assert_called_once_with(
        conveying_call_payload, False
    )

    mock_session.commit.assert_called_once()
    mock_session.rollback.assert_not_called()


def test_save_assignment_details_raises_when_assignment_not_created(
    service,
    mock_session,
    mock_assignment_service,
    validated_request,
):
    mock_assignment_service.create_new_assignment.return_value = {}

    with pytest.raises(Exception, match="Error saving the assignment details"):
        service.save_assignment_details(validated_request)

    mock_session.rollback.assert_called_once()
    mock_session.commit.assert_not_called()


