from src.service.madrid.assignment_payload_mapper import AssignmentPayloadMapper

def process_event(self, madridEvent):
    self._logger.info(
        "Processing Madrid event-id: %s", madridEvent.event_id
    )

    trademark_raw = self._trademark_client.fetch_by_serial(madridEvent.serial_number)
    trademark_raw = json.loads(trademark_raw)
    trademark_data = Trademark.from_dict(trademark_raw)

    assignment_payload = AssignmentPayloadMapper.build(
        trademark_data=trademark_data,
        madrid_event=madridEvent,
    )

    self._logger.info("Assignment payload built successfully")

    assignment_response = self._assignment_client.create_assignment(assignment_payload)

    assignment_id = assignment_response.get("data", {}).get("assignment_id")
    self._logger.info("Assignment created successfully: %s", assignment_id)
