from dataclasses import dataclass, field
from typing import Optional, List
from dataclasses_json import dataclass_json, config, CatchAll
from marshmallow import INCLUDE


@dataclass_json(undefined=INCLUDE)
@dataclass
class Address:
    global_identifier: Optional[str] = None
    primary_ind: Optional[bool] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class ElectronicAddress(Address):
    unknown_fields: CatchAll = None
    email: Optional[str] = None
    electronictype: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class MailingAddress(Address):
    unknown_fields: CatchAll = None
    format_type: Optional[str] = None
    address_type_ct: Optional[str] = None
    category: Optional[str] = None
    name_line_one: Optional[str] = None
    name_line_two: Optional[str] = None
    full_name: Optional[str] = None
    organization_name: Optional[str] = None
    street_line_one: Optional[str] = None
    street_line_two: Optional[str] = None
    city_name: Optional[str] = None
    postal_code: Optional[str] = None
    state_geo_code: Optional[str] = None
    geographic_region_name: Optional[str] = None
    country_code: Optional[str] = None
    country_name: Optional[str] = None
    free_format_address: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class TelecomAddress(Address):
    unknown_fields: CatchAll = None
    number: Optional[str] = None
    submitted_number: Optional[str] = None
    extension: Optional[str] = None
    telecom_format_code: Optional[str] = None
    telecom_type: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class ContactAddress:
    unknown_fields: CatchAll = None
    mailing_addresses: Optional[List[MailingAddress]] = None
    electronic_addresses: Optional[List[ElectronicAddress]] = None
    telecom_addresses: Optional[List[TelecomAddress]] = None
    primary_contact_str: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class Citizenship:
    unknown_fields: CatchAll = None
    state_geo_code: Optional[str] = None
    geographic_region_name: Optional[str] = None
    country_code: Optional[str] = None
    country_name: Optional[str] = None
    country_role_ct: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class AssumedName:
    unknown_fields: CatchAll = None
    intrest_party_assumed_name_id: Optional[int] = None
    assumed_name_optinal_ctcd: Optional[str] = None
    assumed_name_type_cd: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class IpInfo:
    unknown_fields: CatchAll = None
    id: Optional[str] = None
    name: Optional[str] = None
    party_code: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class PartyOwner:
    unknown_fields: CatchAll = None
    id: Optional[str] = None
    name: Optional[str] = None
    party_code: Optional[str] = None
    composed_of: Optional[str] = None
    legal_entity: Optional[str] = None
    legal_entity_statement_tx: Optional[str] = None
    given_name: Optional[str] = None
    suffix: Optional[str] = None
    middle_name: Optional[str] = None
    family_name: Optional[str] = None
    prefix_name: Optional[str] = None
    individual_minor_indicator: Optional[str] = None
    primary_EAG_id: Optional[int] = field(
        default=None,
        metadata=config(field_name="primaryEAGid")
    )
    assumed_name: Optional[AssumedName] = None
    contact_address: Optional[ContactAddress] = None
    citizenship: Optional[Citizenship] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class PriorOwner:
    unknown_fields: CatchAll = None
    owner_sequence_no: Optional[int] = None
    party_role_seq_no: Optional[str] = None
    tm_party_role_id: Optional[int] = None
    docket_reference_no: Optional[str] = None
    email_authorized: Optional[str] = None
    ip_info: Optional[IpInfo] = None
    owner_type_cd: Optional[str] = None
    reel_number: Optional[str] = None
    frame_number: Optional[str] = None
    assignment_name_change: Optional[str] = None
    assignment_date: Optional[str] = None


@dataclass_json(undefined=INCLUDE)
@dataclass
class Trademark:
    unknown_fields: CatchAll = None
    prior_owners: Optional[List[PriorOwner]] = None
    owners: Optional[List[PartyOwner]] = None
    registration_number: Optional[int] = None
