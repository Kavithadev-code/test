def test_save_conveying_parties_success(mock_service, mock_conveying_repo):
    mock_conveying_repo.save_conveying_parties.return_value = SAVE_RETURN_VALUE

    result = mock_service.save_conveying_parties(SERVICE_INPUT)

    mock_conveying_repo.save_conveying_parties.assert_called_once()
    assert result == SAVE_RETURN_VALUE


def test_save_conveying_parties_failure(mock_service, mock_conveying_repo):
    mock_conveying_repo.save_conveying_parties.side_effect = Exception("Database Exception")

    with pytest.raises(Exception, match="Database Exception"):
        mock_service.save_conveying_parties(SERVICE_INPUT)

    mock_conveying_repo.save_conveying_parties.assert_called_once()