import json
import requests
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)


def process_event(self, madridEvent):
    env_config = config.CURRENT_ENV_CONFIG

    assignment_url = env_config.get("ASSIGNMENT_API_URL")
    conveying_url = env_config.get("CONVEYING_PARTIES_API_URL")

    assignment_payload = {
        "formType": "TRADEMARK",
        "name": f"TM Assignment {getattr(madridEvent, 'serial_number', '')}",
        "isMultiAssignment": False,
        "multiAssignmentOrderNumber": None,
        "isResubmission": False,
        "isReviewed": False,
    }

    print("ASSIGNMENT PAYLOAD")
    print(json.dumps(assignment_payload, indent=2, default=str))

    assignment_response = requests.post(
        url=assignment_url,
        json=assignment_payload,
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
        verify=False,
        timeout=60,
    )

    print("ASSIGNMENT STATUS:", assignment_response.status_code)
    print("ASSIGNMENT RESPONSE:", assignment_response.text)
    assignment_response.raise_for_status()

    assignment_json = assignment_response.json()
    assignment_id = (
        assignment_json.get("successResponse", {})
        .get("data", {})
        .get("assignmentId")
    )

    if not assignment_id:
        raise Exception("assignmentId not found in create assignment response")

    conveying_payload = ConveyingPartyPayloadMapper.generate_payload(
        madrid_event=madridEvent,
        assignment_id=assignment_id,
    )

    print("CONVEYING PAYLOAD")
    print(json.dumps(conveying_payload, indent=2, default=str))

    conveying_response = requests.post(
        url=conveying_url,
        json=conveying_payload,
        headers={
            "Content-Type": "application/json",
            "Accept": "application/json",
        },
        verify=False,
        timeout=60,
    )

    print("CONVEYING STATUS:", conveying_response.status_code)
    print("CONVEYING RESPONSE:", conveying_response.text)
    conveying_response.raise_for_status()
