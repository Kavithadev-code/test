from typing import Any, Dict, List, Optional


class AssignmentPayloadMapper:
    DEFAULT_LOCK_CONTROL_NUMBER = 1
    DEFAULT_CLIENT_IP = "127.0.0.1"
    DEFAULT_SIGNATURE_NAME = "Madrid Batch"
    DEFAULT_ELECTRONIC_SIGNATURE = "Y"

    @classmethod
    def build(
        cls,
        trademark_data: Any,
        conveying_parties: Optional[List[Any]] = None,
        receiving_parties: Optional[List[Any]] = None,
        fk_status_id: Optional[int] = None,
        fk_assignment_type_id: Optional[int] = None,
        madrid_event: Any = None,
    ) -> Dict[str, Any]:
        registration_number = cls._get_value(
            trademark_data,
            ["registration_number", "registrationNumber"]
        )

        payload: Dict[str, Any] = {
            "name": cls._build_assignment_name(registration_number),
            "fk_status_id": fk_status_id,
            "fk_assignment_type_id": fk_assignment_type_id,
            "lock_control_number": cls.DEFAULT_LOCK_CONTROL_NUMBER,
            "tracking_number": cls._safe_str(registration_number),
            "client_ip": cls.DEFAULT_CLIENT_IP,
            "signature_full_name": cls.DEFAULT_SIGNATURE_NAME,
            "electronic_signature": cls.DEFAULT_ELECTRONIC_SIGNATURE,
            "conveying_parties": cls._map_parties(conveying_parties or []),
            "receiving_parties": cls._map_parties(receiving_parties or []),
        }

        assignment_date = cls._get_event_date(madrid_event)
        if assignment_date:
            payload["signature_date"] = assignment_date

        # remove None values so schema load is cleaner
        return {k: v for k, v in payload.items() if v is not None}

    @classmethod
    def _build_assignment_name(cls, registration_number: Optional[Any]) -> str:
        if registration_number:
            return f"TM Assignment {registration_number}"
        return "TM Assignment"

    @classmethod
    def _map_parties(cls, parties: List[Any]) -> List[Dict[str, Any]]:
        mapped: List[Dict[str, Any]] = []

        for party in parties:
            mapped_party = cls._map_single_party(party)
            if mapped_party:
                mapped.append(mapped_party)

        return mapped

    @classmethod
    def _map_single_party(cls, party: Any) -> Optional[Dict[str, Any]]:
        if not party:
            return None

        name = cls._get_value(
            party,
            ["name", "owner_name", "full_name", "party_name"]
        )

        first_name = cls._get_value(party, ["first_name", "firstName", "given_name", "givenName"])
        last_name = cls._get_value(party, ["last_name", "lastName", "family_name", "familyName"])

        if not name:
            if first_name and last_name:
                name = f"{first_name} {last_name}"
            elif first_name:
                name = first_name
            elif last_name:
                name = last_name

        if not name:
            return None

        payload: Dict[str, Any] = {
            "name": name,
            "party_code": cls._get_party_code(party),
        }

        email = cls._extract_email(party)
        if email:
            payload["email"] = email

        phone = cls._extract_phone(party)
        if phone:
            payload["phone"] = phone

        address = cls._extract_address(party)
        payload.update(address)

        return {k: v for k, v in payload.items() if v is not None}

    @classmethod
    def _get_party_code(cls, party: Any) -> str:
        party_code = cls._get_value(party, ["party_code", "partyCode"])
        if party_code:
            return str(party_code)

        # fallback
        return "O"

    @classmethod
    def _extract_address(cls, party: Any) -> Dict[str, Any]:
        address = cls._get_nested_value(
            party,
            [
                ["address"],
                ["mailing_address"],
                ["mailingAddress"],
                ["contact_address"],
                ["contactAddress"],
            ]
        )

        if not address:
            return {}

        return {
            "address_line_1": cls._get_value(address, ["address_line_1", "addressLine1", "line1", "street1"]),
            "address_line_2": cls._get_value(address, ["address_line_2", "addressLine2", "line2", "street2"]),
            "city": cls._get_value(address, ["city"]),
            "state": cls._get_value(address, ["state", "state_code", "stateCode"]),
            "postal_code": cls._get_value(address, ["postal_code", "postalCode", "zip_code", "zipCode"]),
            "country_code": cls._get_value(address, ["country_code", "countryCode", "country"]),
        }

    @classmethod
    def _extract_email(cls, party: Any) -> Optional[str]:
        email = cls._get_value(party, ["email", "email_address", "emailAddress"])
        if email:
            return str(email)

        electronic_address = cls._get_nested_value(
            party,
            [
                ["electronic_address"],
                ["electronicAddress"],
                ["contact_address", "electronic_address"],
                ["contactAddress", "electronicAddress"],
            ]
        )

        nested_email = cls._get_value(
            electronic_address,
            ["email", "email_address", "emailAddress"]
        )
        return str(nested_email) if nested_email else None

    @classmethod
    def _extract_phone(cls, party: Any) -> Optional[str]:
        phone = cls._get_value(party, ["phone", "phone_number", "phoneNumber"])
        if phone:
            return str(phone)

        telecom = cls._get_nested_value(
            party,
            [
                ["telecom"],
                ["contact_address", "telecom"],
                ["contactAddress", "telecom"],
            ]
        )

        nested_phone = cls._get_value(
            telecom,
            ["phone", "phone_number", "phoneNumber"]
        )
        return str(nested_phone) if nested_phone else None

    @classmethod
    def _get_event_date(cls, madrid_event: Any) -> Optional[str]:
        if not madrid_event:
            return None

        event_date = cls._get_value(madrid_event, ["event_date", "eventDate"])
        if not event_date:
            return None

        if hasattr(event_date, "isoformat"):
            return event_date.isoformat()

        return str(event_date)

    @staticmethod
    def _get_value(data: Any, keys: List[str], default: Any = None) -> Any:
        if data is None:
            return default

        for key in keys:
            if isinstance(data, dict):
                value = data.get(key)
                if value is not None:
                    return value
            else:
                if hasattr(data, key):
                    value = getattr(data, key)
                    if value is not None:
                        return value

        return default

    @classmethod
    def _get_nested_value(
        cls,
        data: Any,
        paths: List[List[str]],
        default: Any = None
    ) -> Any:
        for path in paths:
            current = data
            found = True

            for key in path:
                current = cls._get_value(current, [key])
                if current is None:
                    found = False
                    break

            if found:
                return current

        return default

    @staticmethod
    def _safe_str(value: Any) -> Optional[str]:
        if value is None:
            return None
        return str(value)
