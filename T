from fastapi import APIRouter, Query
from app.service.patent import search_public_patent

public_router = APIRouter()


@public_router.get("/search/public/patent/reel-frame")
async def search_patent_by_reel_frame(
    reel_number: int = Query(..., alias="reelNumber"),
    frame_number: int = Query(..., alias="frameNumber"),
    current_page: int = Query(1, alias="currentPage"),
    records_per_page: int = Query(25, alias="recordsPerPage", ge=1, le=100),
):
    return search_public_patent.get_assignment_details_patent(
        reel_number=reel_number,
        frame_number=frame_number,
        current_page=current_page,
        rows_per_page=records_per_page,
    )