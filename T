import pytest
from unittest.mock import MagicMock, patch

from service.madrid_batch_runner import MadridBatchRunner
import service.madrid_batch_runner as runner_module


class TestMadridBatchRunner:

    @pytest.fixture
    def mock_repo(self):
        return MagicMock()

    @pytest.fixture
    def mock_processor(self):
        return MagicMock()

    @pytest.fixture
    def mock_session(self):
        return MagicMock()

    @pytest.fixture
    def runner(self, mock_repo, mock_processor, mock_session):
        return MadridBatchRunner(
            madrid_event_repo=mock_repo,
            processor=mock_processor,
            session=mock_session,
        )

    def test_process_madrid_returns_when_no_events_found(
        self, runner, mock_repo, mock_processor, mock_session
    ):
        mock_repo.claim_pending_events.return_value = None

        runner.process_madrid()

        mock_repo.claim_pending_events.assert_called_once()
        mock_processor.process_event.assert_not_called()
        mock_repo.finalize_event_status.assert_not_called()
        mock_session.commit.assert_not_called()

    def test_process_madrid_processes_single_event_successfully(
        self, runner, mock_repo, mock_processor, mock_session
    ):
        event = {
            "event_id": 101,
            "event_type": "MADRID",
            "serial_number": "SN123",
        }
        mock_repo.claim_pending_events.return_value = event

        with patch.object(runner_module, "MadridEventInput") as mock_input_cls:
            madrid_input = MagicMock()
            mock_input_cls.return_value = madrid_input

            runner.process_madrid()

            mock_input_cls.assert_called_once_with(
                event_id=101,
                event_type="MADRID",
                serial_number="SN123",
            )
            mock_processor.process_event.assert_called_once_with(madrid_input)
            mock_repo.finalize_event_status.assert_called_once_with(
                event_id=101,
                status=runner_module.AssignmentStatus.MADRID_PROCESSED,
                error_msg=None,
            )
            mock_session.commit.assert_called_once()

    def test_process_madrid_processes_list_and_skips_empty_and_missing_event_id(
        self, runner, mock_repo, mock_processor, mock_session
    ):
        valid_event = {
            "event_id": 202,
            "event_type": "MADRID",
            "serial_number": "SN202",
        }
        empty_event = {}
        missing_id_event = {
            "event_type": "MADRID",
            "serial_number": "SN999",
        }

        mock_repo.claim_pending_events.return_value = [
            empty_event,
            missing_id_event,
            valid_event,
        ]

        with patch.object(runner_module, "MadridEventInput") as mock_input_cls:
            madrid_input = MagicMock()
            mock_input_cls.return_value = madrid_input

            runner.process_madrid()

            mock_input_cls.assert_called_once_with(
                event_id=202,
                event_type="MADRID",
                serial_number="SN202",
            )
            mock_processor.process_event.assert_called_once_with(madrid_input)
            mock_repo.finalize_event_status.assert_called_once_with(
                event_id=202,
                status=runner_module.AssignmentStatus.MADRID_PROCESSED,
                error_msg=None,
            )
            mock_session.commit.assert_called_once()

    def test_process_madrid_marks_event_failed_when_processor_raises(
        self, runner, mock_repo, mock_processor, mock_session
    ):
        event = {
            "event_id": 303,
            "event_type": "MADRID",
            "serial_number": "SN303",
        }
        mock_repo.claim_pending_events.return_value = event
        mock_processor.process_event.side_effect = Exception("processing failed")

        with patch.object(runner_module, "MadridEventInput") as mock_input_cls:
            madrid_input = MagicMock()
            mock_input_cls.return_value = madrid_input

            runner.process_madrid()

            mock_input_cls.assert_called_once_with(
                event_id=303,
                event_type="MADRID",
                serial_number="SN303",
            )
            mock_processor.process_event.assert_called_once_with(madrid_input)
            mock_repo.finalize_event_status.assert_called_once_with(
                event_id=303,
                status=runner_module.AssignmentStatus.MADRID_FAIL,
                error_msg="processing failed",
            )
            mock_session.commit.assert_called_once()

    def test_process_madrid_handles_mixed_success_and_failure_events(
        self, runner, mock_repo, mock_processor, mock_session
    ):
        event_1 = {
            "event_id": 401,
            "event_type": "MADRID",
            "serial_number": "SN401",
        }
        event_2 = {
            "event_id": 402,
            "event_type": "MADRID",
            "serial_number": "SN402",
        }

        mock_repo.claim_pending_events.return_value = [event_1, event_2]

        def process_side_effect(arg):
            if getattr(arg, "event_id", None) == 402:
                raise Exception("second event failed")

        with patch.object(runner_module, "MadridEventInput") as mock_input_cls:
            input_1 = MagicMock()
            input_1.event_id = 401
            input_2 = MagicMock()
            input_2.event_id = 402
            mock_input_cls.side_effect = [input_1, input_2]

            mock_processor.process_event.side_effect = process_side_effect

            runner.process_madrid()

            assert mock_input_cls.call_count == 2
            assert mock_processor.process_event.call_count == 2

            assert mock_repo.finalize_event_status.call_count == 2
            mock_repo.finalize_event_status.assert_any_call(
                event_id=401,
                status=runner_module.AssignmentStatus.MADRID_PROCESSED,
                error_msg=None,
            )
            mock_repo.finalize_event_status.assert_any_call(
                event_id=402,
                status=runner_module.AssignmentStatus.MADRID_FAIL,
                error_msg="second event failed",
            )

            assert mock_session.commit.call_count == 2
