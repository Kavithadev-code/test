import pytest
from unittest.mock import MagicMock
from sqlalchemy.exc import SQLAlchemyError
from sqlalchemy.orm import Session

from src.repositories.assignment.individual_phone_info_repository import (
    IndividualPhoneInfoRepository,
)
from src.exceptions.database_exception import DatabaseException


PHONE_INPUT_DATA = [
    {
        "type": "MOBILE",
        "phoneNumber": "1234567890",
        "extension": "101",
    },
    {
        "type": "HOME",
        "phoneNumber": "5555555555",
        "extension": "",
    },
]


@pytest.fixture
def mock_db_session():
    return MagicMock(spec=Session)


@pytest.fixture
def mock_repo(mock_db_session):
    return IndividualPhoneInfoRepository(mock_db_session)


def test_save_individual_phone_info_commit_true(mock_repo, mock_db_session):
    result = mock_repo.save_individual_phone_info(
        PHONE_INPUT_DATA,
        individual_id=101,
        commit_flag=True,
    )

    assert mock_db_session.add.call_count == 2
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    assert len(result) == 2


def test_save_individual_phone_info_commit_false(mock_repo, mock_db_session):
    result = mock_repo.save_individual_phone_info(
        PHONE_INPUT_DATA,
        individual_id=101,
        commit_flag=False,
    )

    assert mock_db_session.add.call_count == 2
    mock_db_session.commit.assert_not_called()
    mock_db_session.flush.assert_called_once()
    assert len(result) == 2


def test_save_individual_phone_info_empty_list(mock_repo, mock_db_session):
    result = mock_repo.save_individual_phone_info(
        [],
        individual_id=101,
        commit_flag=True,
    )

    mock_db_session.add.assert_not_called()
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    assert result == []


def test_save_individual_phone_info_sqlalchemy_error_on_add(
    mock_repo, mock_db_session
):
    mock_db_session.add.side_effect = SQLAlchemyError("db failure")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.save_individual_phone_info(
            PHONE_INPUT_DATA,
            individual_id=101,
            commit_flag=True,
        )

    mock_db_session.rollback.assert_called_once()
    assert "Error saving IndividualPhoneInfo details" in str(exc_info.value)