def derive_names(given_name, family_name, full_name):
    # Case 1: given + family provided
    if given_name or family_name:
        first = given_name
        last = family_name
        middle = None
        return first, middle, last

    # Case 2: nothing to parse
    if not full_name:
        return None, None, None

    # Case 3: semicolon format (e.g., "Last; First; Middle")
    if ";" in full_name:
        parts = [p.strip() for p in full_name.split(";") if p.strip()]
        if len(parts) == 3:
            return parts[1], parts[2], parts[0]   # First, Middle, Last
        elif len(parts) == 2:
            return parts[1], None, parts[0]       # First, None, Last

    # Case 4: space-separated format
    parts = [p.strip() for p in full_name.split() if p.strip()]

    if len(parts) == 1:
        return parts[0], None, None

    if len(parts) == 2:
        return parts[0], None, parts[1]

    if len(parts) >= 3:
        first = parts[0]
        last = parts[-1]
        middle = " ".join(parts[1:-1])  # supports multiple middle names
        return first, middle, last

    return None, None, None