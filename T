def test_save_receiving_parties_exception_rolls_back(
    mock_repo, mock_db_session
):
    input_data = SAVE_INPUT_DATA.copy()
    input_data["receiving_party_id"] = 10

    mock_db_session.query.side_effect = Exception("Database Exception")

    with pytest.raises(Exception, match="Database Exception"):
        mock_repo.save_receiving_parties(
            input_data,
            type_id=1,
            address_id=100,
            domestic_individual_id=200,
            domestic_address_info_id=300,
            commit_flag=True,
        )

    mock_db_session.rollback.assert_called_once()
    mock_db_session.commit.assert_not_called()