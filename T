from datetime import datetime
from typing import Any, Dict, List, Optional


class ReceivingPartyPayloadMapper:
    @staticmethod
    def generate_payloads(
        receiving_parties: List[Any],
        assignment_id: int,
        form_type: str = "TRADEMARK",
    ) -> List[Dict[str, Any]]:
        payloads: List[Dict[str, Any]] = []

        for owner in receiving_parties or []:
            payload = ReceivingPartyPayloadMapper._build_payload(
                owner=owner,
                assignment_id=assignment_id,
                form_type=form_type,
            )
            if payload:
                payloads.append(payload)

        return payloads

    @staticmethod
    def _build_payload(
        owner: Any,
        assignment_id: int,
        form_type: str,
    ) -> Optional[Dict[str, Any]]:
        ip_info = getattr(owner, "ip_info", None)
        if not ip_info:
            return None

        party_code = getattr(ip_info, "party_code", None)
        receiving_type = "INDIVIDUAL" if party_code == "I" else "ENTITY"

        contact_address = getattr(ip_info, "contact_address", None)
        mailing_addresses = getattr(contact_address, "mailing_addresses", None) if contact_address else None
        electronic_addresses = getattr(contact_address, "electronic_addresses", None) if contact_address else None
        citizenship = getattr(ip_info, "citizenship", None)

        mailing_address = mailing_addresses[0] if mailing_addresses else None
        electronic_address = electronic_addresses[0] if electronic_addresses else None

        if not mailing_address:
            raise ValueError("mailing_address missing for receiving party")

        receiving_email = (
            getattr(electronic_address, "electronic_address_text", None)
            or getattr(electronic_address, "email", None)
            or "test@test.com"
        )

        citizenship_id = ReceivingPartyPayloadMapper._safe_int(
            getattr(citizenship, "country_id", None) or getattr(citizenship, "country_code", None)
        )
        citizenship_name = (
            getattr(citizenship, "country_name", None)
            or getattr(citizenship, "country_code", None)
        )

        citizenship_state_id = ReceivingPartyPayloadMapper._safe_int(
            getattr(citizenship, "state_id", None) or getattr(citizenship, "state_geo_code", None)
        )
        citizenship_state = (
            getattr(citizenship, "geographic_region_name", None)
            or getattr(citizenship, "state_name", None)
            or getattr(citizenship, "state_geo_code", None)
        )

        postal_code = getattr(mailing_address, "postal_code", None)
        zip_code = ReceivingPartyPayloadMapper._safe_int(
            ReceivingPartyPayloadMapper._first_five_digits(postal_code)
        )

        address_info = {
            "addressId": None,
            "attention": None,
            "addressLineOne": (
                getattr(mailing_address, "street_line_one", None)
                or getattr(mailing_address, "street_address_line_text", None)
            ),
            "addressLineTwo": (
                getattr(mailing_address, "street_line_two", None)
                or getattr(mailing_address, "free_format_address", None)
            ),
            "city": getattr(mailing_address, "city_name", None),
            "stateId": ReceivingPartyPayloadMapper._safe_int(
                getattr(mailing_address, "state_id", None)
                or getattr(mailing_address, "state_geo_code", None)
            ),
            "state": (
                getattr(mailing_address, "geographic_region_name", None)
                or getattr(mailing_address, "state_name", None)
                or getattr(mailing_address, "state_geo_code", None)
            ),
            "zipCode": zip_code,
            "countryId": ReceivingPartyPayloadMapper._safe_int(
                getattr(mailing_address, "country_id", None)
                or getattr(mailing_address, "country_code", None)
            ),
            "country": (
                getattr(mailing_address, "country_name", None)
                or getattr(mailing_address, "country_code", None)
            ),
            "lockControlNumber": 1,
        }

        payload: Dict[str, Any] = {
            "assignmentId": assignment_id,
            "formType": form_type,
            "receivingType": receiving_type,
            "receivingEmail": receiving_email,
            "citizenshipId": citizenship_id,
            "citizenship": citizenship_name,
            "citizenshipStateId": citizenship_state_id,
            "citizenshipState": citizenship_state,
            "executionDate": datetime.utcnow().strftime("%Y-%m-%d"),
            "addressInfo": address_info,
        }

        if receiving_type == "INDIVIDUAL":
            first_name, last_name = ReceivingPartyPayloadMapper._derive_names(
                given_name=getattr(ip_info, "given_name", None),
                family_name=getattr(ip_info, "family_name", None),
                full_name=getattr(ip_info, "name", None),
            )

            payload["individual"] = {
                "individualId": None,
                "prefix": getattr(ip_info, "prefix_name", None),
                "firstName": first_name,
                "middleName": getattr(ip_info, "middle_name", None),
                "lastName": last_name,
                "suffix": getattr(ip_info, "suffix", None),
                "lockControlNumber": 1,
            }
        else:
            payload["entity"] = {
                "entityId": None,
                "entityName": getattr(ip_info, "name", None),
                "legalEntityTypeId": ReceivingPartyPayloadMapper._safe_int(
                    getattr(ip_info, "legal_entity", None)
                ),
                "lockControlNumber": 1,
            }

        return payload

    @staticmethod
    def _first_five_digits(value: Any) -> Optional[str]:
        if value is None:
            return None
        digits = "".join(ch for ch in str(value) if ch.isdigit())
        return digits[:5] if digits else None

    @staticmethod
    def _safe_int(value: Any) -> Optional[int]:
        try:
            if value is None:
                return None
            digits = "".join(ch for ch in str(value) if ch.isdigit())
            return int(digits) if digits else None
        except (TypeError, ValueError):
            return None

    @staticmethod
    def _derive_names(
        given_name: Optional[str] = None,
        family_name: Optional[str] = None,
        full_name: Optional[str] = None,
    ) -> tuple[Optional[str], Optional[str]]:
        if given_name:
            return given_name, family_name

        if not full_name:
            return None, None

        if "," in full_name:
            parts = [p.strip() for p in full_name.split(",") if p.strip()]
            if len(parts) >= 2:
                return parts[1], parts[0]

        parts = [p.strip() for p in full_name.split() if p.strip()]
        if len(parts) >= 2:
            return " ".join(parts[:-1]), parts[-1]

        return full_name, full_name