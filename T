def get_assignment_details_patent(reel_number, frame_number, current_page=1, rows_per_page=10):
    try:
        logger.info("search_public_patent_assignment_details: Received request")

        query = public_patent_queries.get_query_public_patent_search_by_reel_frame(
            reel_number, frame_number
        )

        result = run_query(query=query, search_type="patent")

        total_hits = result["hits"]["total"]["value"]
        has_backend_pagination = total_hits > config.rows_to_be_avoided_for_pagination

        if not has_backend_pagination:
            return create_search_success_response(
                search_public_patent_data(result, {}),
                total_hits,
                has_backend_pagination
            )

        paged_result = get_paginated_query_results(query, current_page, rows_per_page)
        message = paged_result.get("_meta", {}).get("message")
        capped_total = paged_result.get("_meta", {}).get("capped_total")

        return create_search_success_response(
            search_public_patent_data(paged_result, {}),
            capped_total,
            has_backend_pagination,
            filtered_hits=0,
            message=message
        )

    except Exception as err:
        logger.exception("search_public_patent_assignment_details failed")
        return create_internal_server_error_response(err)