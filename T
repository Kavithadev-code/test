def test_save_correspondence_info_sqlalchemy_error_on_add(
    mock_repo, mock_db_session
):
    correspondence = MagicMock()
    correspondence.correspondent_id = None
    mock_db_session.add.side_effect = SQLAlchemyError("db failure")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.save_correspondence_info(
            correspondence, commit_flag=True
        )

    mock_db_session.rollback.assert_called_once()
    assert "Error saving Assignment details" in str(exc_info.value)


def test_save_correspondence_info_sqlalchemy_error_on_commit(
