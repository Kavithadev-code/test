import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError
from sqlalchemy.orm import Session

from src.repositories.assignment.entity_repository import EntityRepository
from src.exceptions.database_exception import DatabaseException


ENTITY_INPUT_DATA = {
    "entity_id": 10,
    "name": "Test Entity",
    "entity_type": "ORGANIZATION"
}


@pytest.fixture
def mock_db_session():
    return MagicMock(spec=Session)


@pytest.fixture
def mock_repo(mock_db_session):
    return EntityRepository(mock_db_session)


@pytest.fixture
def mock_entity():
    obj = MagicMock()
    obj.entity_id = 10
    return obj


def test_save_entity_info_new_commit_true(mock_repo, mock_db_session):
    entity = MagicMock()
    entity.entity_id = None

    result = mock_repo.save_entity_info(entity, commit_flag=True)

    mock_db_session.add.assert_called_once_with(entity)
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == entity


def test_save_entity_info_new_commit_false(mock_repo, mock_db_session):
    entity = MagicMock()
    entity.entity_id = None

    result = mock_repo.save_entity_info(entity, commit_flag=False)

    mock_db_session.add.assert_called_once_with(entity)
    mock_db_session.commit.assert_not_called()
    mock_db_session.flush.assert_called_once()
    mock_db_session.refresh.assert_called_once_with(entity)
    assert result == entity


def test_save_entity_info_existing_entity(mock_repo, mock_db_session):
    entity = MagicMock()
    entity.entity_id = 99

    result = mock_repo.save_entity_info(entity, commit_flag=True)

    mock_db_session.add.assert_not_called()
    mock_db_session.commit.assert_not_called()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == entity


def test_save_entity_info_sqlalchemy_error_on_add(mock_repo, mock_db_session):
    entity = MagicMock()
    entity.entity_id = None
    mock_db_session.add.side_effect = SQLAlchemyError("db failure")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.save_entity_info(entity, commit_flag=True)

    mock_db_session.rollback.assert_called_once()
    assert "error adding entity details" in str(exc_info.value).lower()


def test_save_entity_info_sqlalchemy_error_on_flush(mock_repo, mock_db_session):
    entity = MagicMock()
    entity.entity_id = None
    mock_db_session.flush.side_effect = SQLAlchemyError("flush failure")

    with pytest.raises(DatabaseException) as exc_info:
