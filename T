import pytest
from unittest.mock import MagicMock, patch

from repositories.conveying_party.conveying_party_repository import ConveyingPartyRepository


class DummySavedEntity:
    def __init__(self, data=None):
        self.data = data or {"ok": True}

    def to_dict(self):
        return self.data


class DummyExistingEntity(DummySavedEntity):
    def set_conveying_party(self, conveying_party_data, type_id):
        self.updated_data = conveying_party_data
        self.updated_type_id = type_id


class DummyConveyingParty:
    @staticmethod
    def from_dict(conveying_party_data, type_id):
        entity = DummySavedEntity(
            {
                "conveying_party_id": conveying_party_data["conveying_party_id"],
                "type_id": type_id,
            }
        )
        entity.source_data = conveying_party_data
        entity.source_type_id = type_id
        return entity


@pytest.fixture
def mock_session():
    return MagicMock()


@pytest.fixture
def repo(mock_session):
    return ConveyingPartyRepository(session=mock_session)


@pytest.fixture
def conveying_party_data():
    return {
        "conveying_party_id": 101
    }


@patch("repositories.conveying_party.conveying_party_repository.ConveyingParty", DummyConveyingParty)
def test_save_conveying_parties_create_new(repo, mock_session, conveying_party_data):
    type_id = 7

    result = repo.save_conveying_parties(conveying_party_data, type_id)

    mock_session.add.assert_called_once()
    saved_entity = mock_session.add.call_args[0][0]
    assert saved_entity.source_data == conveying_party_data
    assert saved_entity.source_type_id == type_id
    mock_session.flush.assert_called_once()
    mock_session.refresh.assert_called_once_with(saved_entity)
    assert result == {
        "conveying_party_id": 101,
        "type_id": 7,
    }


@patch("repositories.conveying_party.conveying_party_repository.ConveyingParty", DummyConveyingParty)
def test_save_conveying_parties_update_existing(repo, mock_session, conveying_party_data):
    type_id = 9
    existing_entity = DummyExistingEntity({"updated": True})

    query_mock = MagicMock()
    filter_mock = MagicMock(return_value=existing_entity)
    query_mock.filter = filter_mock
    mock_session.query.return_value = query_mock

    result = repo.save_conveying_parties(conveying_party_data, type_id)

    mock_session.query.assert_called_once()
    filter_mock.assert_called_once()
    mock_session.add.assert_not_called()
    mock_session.flush.assert_called_once()
    mock_session.refresh.assert_called_once_with(existing_entity)

    assert existing_entity.updated_data == conveying_party_data
    assert existing_entity.updated_type_id == type_id
    assert result == {"updated": True}


