def transform_properties_to_app_numbers(parsed_data):
    """
    Safely replace properties with applicationNumber list.
    """

    if not isinstance(parsed_data, list):
        return parsed_data

    for item in parsed_data:

        # Skip if not dict (this is your current failure)
        if not isinstance(item, dict):
            continue

        properties = item.get("properties", [])

        # Ensure properties is a list
        if not isinstance(properties, list):
            continue

        item["properties"] = [
            prop.get("applicationNumber")
            for prop in properties
            if isinstance(prop, dict) and prop.get("applicationNumber")
        ]

    return parsed_data