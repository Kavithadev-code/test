composed_of_party_list = []

for composed_owner in composed_parties or []:
    composed_ip_info = getattr(composed_owner, "ip_info", None) or composed_owner
    composed_party_code = getattr(composed_ip_info, "party_code", None)
    composed_type = "INDIVIDUAL" if composed_party_code == "I" else "ENTITY"

    if composed_type == "INDIVIDUAL":
        first_name, last_name = ReceivingPartyPayloadMapper._derive_names(
            getattr(composed_ip_info, "given_name", None),
            getattr(composed_ip_info, "family_name", None),
            getattr(composed_ip_info, "name", None),
        )

        individual_block = {
            "individualId": 1,
            "prefix": getattr(composed_ip_info, "prefix_name", None),
            "firstName": first_name or "UNKNOWN",
            "middleName": getattr(composed_ip_info, "middle_name", None),
            "lastName": last_name or "UNKNOWN",
            "suffix": getattr(composed_ip_info, "suffix", None),
            "lockControlNumber": 1,
        }

        composed_payload = {
            "composedofPartyType": "INDIVIDUAL",
            "individual": individual_block.copy(),
        }

    else:
        entity_block = {
            "entityId": 1,
            "entityName": getattr(composed_ip_info, "name", None) or "UNKNOWN ENTITY",
            "legalEntityTypeId": ReceivingPartyPayloadMapper._safe_int(
                getattr(composed_ip_info, "legal_entity", None)
            ) or 1,
            "lockControlNumber": 1,
        }

        composed_payload = {
            "composedofPartyType": "ENTITY",
            "entity": entity_block.copy(),
        }

    composed_of_party_list.append(composed_payload)