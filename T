import pytest
from unittest.mock import MagicMock, patch

from repositories.assignment.conveying_party_repository import ConveyingPartyRepository


@pytest.fixture
def mock_db_session():
    return MagicMock()


@pytest.fixture
def mock_repo(mock_db_session):
    return ConveyingPartyRepository(session=mock_db_session)


@patch("repositories.assignment.conveying_party_repository.ConveyingParty")
def test_save_conveying_parties_success(mock_conveying_party, mock_repo, mock_db_session):
    save_input_data = {"conveying_party_id": None}

    mock_entity = MagicMock()
    mock_entity.to_dict.return_value = {"saved": True}
    mock_conveying_party.from_dict.return_value = mock_entity

    result = mock_repo.save_conveying_parties(save_input_data, type_id=1)

    mock_conveying_party.from_dict.assert_called_once_with(save_input_data, 1)
    mock_db_session.add.assert_called_once_with(mock_entity)
    mock_db_session.flush.assert_called_once()
    mock_db_session.refresh.assert_called_once_with(mock_entity)
    assert result == {"saved": True}


@patch("repositories.assignment.conveying_party_repository.ConveyingParty")
def test_save_conveying_parties_db_error(mock_conveying_party, mock_repo, mock_db_session):
    save_input_data = {"conveying_party_id": None}

    mock_entity = MagicMock()
    mock_conveying_party.from_dict.return_value = mock_entity
    mock_db_session.add.side_effect = Exception("Database Exception")

    with pytest.raises(Exception, match="Database Exception"):
        mock_repo.save_conveying_parties(save_input_data, type_id=1)

    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()