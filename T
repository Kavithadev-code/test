def test_get_address_info_by_address_id_exception(repository, mock_session):
    mock_session.query.side_effect = Exception("unexpected error")

    with pytest.raises(DatabaseException) as exc_info:
        repository.get_address_info_by_address_id(123)

    assert "Unable to get Address Info" in str(exc_info.value)


def test_upsert_address_update_with_commit_true(repository, mock_session):
    address_info = {
        "address_id": 10,
        "city": "Dallas",
        "state": "TX"
    }

    mock_address = MagicMock()

    mock_query = MagicMock()
    mock_query.get.return_value = mock_address
    mock_session.query.return_value = mock_query

    result = repository.upsert_address(address_info, commit_flag=True)

    mock_session.query.assert_called_once()
    mock_query.get.assert_called_once_with(10)
    mock_address.set_address.assert_called_once_with(address_info)
    mock_session.commit.assert_called_once()
    mock_session.flush.assert_not_called()
    mock_session.refresh.assert_not_called()
    assert result == mock_address


def test_upsert_address_update_with_commit_false(repository, mock_session):
    address_info = {
        "address_id": 10,
        "city": "Dallas",
        "state": "TX"
    }

    mock_address = MagicMock()

    mock_query = MagicMock()
    mock_query.get.return_value = mock_address
    mock_session.query.return_value = mock_query

    result = repository.upsert_address(address_info, commit_flag=False)

    mock_address.set_address.assert_called_once_with(address_info)
    mock_session.commit.assert_not_called()
    mock_session.flush.assert_called_once()
    mock_session.refresh.assert_called_once_with(mock_address)
    assert result == mock_address


@patch("src.repositories.assignment.address_repository.Address")
def test_upsert_address_create_new_address(mock_address_class, repository):
    address_info = {
        "city": "Dallas",
        "state": "TX"
    }

    mock_address_entity = MagicMock()
    mock_address_class.from_dict.return_value = mock_address_entity

    with patch.object(repository, "save_address_info", return_value=mock_address_entity) as mock_save:
        result = repository.upsert_address(address_info, commit_flag=True)

    mock_address_class.from_dict.assert_called_once_with(address_info)
    mock_save.assert_called_once_with(mock_address_entity)
    assert result == mock_address_entity


