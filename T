@patch("repositories.conveying_party.conveying_party_repository.logger")
@patch("repositories.conveying_party.conveying_party_repository.ConveyingParty", DummyConveyingParty)
def test_save_conveying_parties_exception(mock_logger, repo, mock_session, conveying_party_data):
    type_id = 3
    mock_session.flush.side_effect = Exception("db failure")

    with pytest.raises(Exception, match="db failure"):
        repo.save_conveying_parties(conveying_party_data, type_id)

    mock_logger.error.assert_called_once()