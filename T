seq_map = {}

for p in all_properties:
    app = p.get("application_number")
    seq = p.get("property_sequence_number")
    if app:
        seq_map[str(app)] = seq

for fp in filtered_properties:
    app_num = fp.get("applicationNumberText")
    if app_num:
        fp["sequence_number"] = seq_map.get(str(app_num))