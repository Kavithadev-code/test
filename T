from typing import Any, Dict, Optional


class ConveyingPartyPayloadMapper:
    @staticmethod
    def generate_payloads(madrid_event: Any, assignment_id: int) -> list[dict]:
        owners = getattr(madrid_event, "owners", None) or []
        payloads = []

        for owner in owners:
            role_seq = getattr(owner, "party_role_seq_no", None)
            if str(role_seq) == "2001":
                payload = ConveyingPartyPayloadMapper._map_owner(owner, assignment_id)
                if payload:
                    payloads.append(payload)

        return payloads

    @staticmethod
    def _map_owner(owner: Any, assignment_id: int) -> Optional[Dict[str, Any]]:
        ip_info = getattr(owner, "ip_info", None)
        if not ip_info:
            return None

        name = getattr(ip_info, "name", None)
        party_code = getattr(ip_info, "party_code", None)
        legal_entity = getattr(ip_info, "legal_entity", None)

        given_name = getattr(ip_info, "given_name", None)
        family_name = getattr(ip_info, "family_name", None)
        middle_name = getattr(ip_info, "middle_name", None)
        prefix_name = getattr(ip_info, "prefix_name", None)
        suffix = getattr(ip_info, "suffix", None)

        citizenship_obj = getattr(ip_info, "citizenship", None)

        citizenship_id = getattr(citizenship_obj, "country_code", None) if citizenship_obj else None
        citizenship = getattr(citizenship_obj, "country_name", None) if citizenship_obj else None
        citizenship_state_id = getattr(citizenship_obj, "state_geo_code", None) if citizenship_obj else None
        citizenship_state = getattr(citizenship_obj, "geographic_region_name", None) if citizenship_obj else None

        first_name, last_name = ConveyingPartyPayloadMapper._derive_names(
            given_name=given_name,
            family_name=family_name,
            full_name=name,
        )

        base_payload = {
            "assignmentId": assignment_id,
            "formType": "TRADEMARK",
            "executionDate": None,
            "citizenshipId": citizenship_id,
            "citizenship": citizenship,
            "citizenshipStateId": citizenship_state_id,
            "citizenshipState": citizenship_state,
            "isMergedEntity": False,
        }

        if party_code == "I":
            base_payload["conveyingType"] = "INDIVIDUAL"
            base_payload["individual"] = {
                "prefix": prefix_name,
                "first_name": first_name,
                "middle_name": middle_name,
                "last_name": last_name,
                "suffix": suffix,
                "lock_control_number": 1,
            }
        else:
            base_payload["conveyingType"] = "ENTITY"
            base_payload["entity"] = {
                "entity_name": name,
                "legal_entity_type_id": legal_entity,
                "lock_control_number": 1,
            }

        return base_payload

    @staticmethod
    def _derive_names(
        given_name: Optional[str],
        family_name: Optional[str],
        full_name: Optional[str],
    ) -> tuple[Optional[str], Optional[str]]:
        if given_name:
            return given_name, family_name

        if not full_name:
            return None, None

        if "," in full_name:
            parts = [p.strip() for p in full_name.split(",") if p.strip()]
            if len(parts) >= 2:
                return parts[1], parts[0]

        parts = [p.strip() for p in full_name.split() if p.strip()]
        if len(parts) >= 2:
            return " ".join(parts[:-1]), parts[-1]

        return full_name, full_name
