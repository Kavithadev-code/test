import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.orm import Session

from src.repositories.assignment.conveying_party_repository import ConveyingPartyRepository


SAVE_INPUT_DATA = {
    "assignment_id": 16592,
    "conveying_party_id": 0,
    "conveying_type": "INDIVIDUAL",
    "execution_date": "2025-05-01",
    "citizenship_id": 100753,
    "citizenship": "UNITED STATES",
    "citizenship_state_id": 0,
    "citizenship_state": "",
    "individual": {
        "individual_id": 60656,
        "prefix": "",
        "suffix": "",
        "first_name": "tatest",
        "last_name": "token",
        "middle_name": ""
    },
    "entity": None,
    "is_merged_entity": 0
}


@pytest.fixture
def mock_db_session():
    return MagicMock(spec=Session)


@pytest.fixture
def mock_repo(mock_db_session):
    return ConveyingPartyRepository(mock_db_session)


@pytest.fixture
def mock_conveying_party():
    mock_obj = MagicMock()
    mock_obj.to_dict.return_value = {
        "assignment_id": 16592,
        "conveying_party_id": 1,
        "conveying_type": "INDIVIDUAL"
    }
    return mock_obj


def test_save_conveying_parties_existing_commit_true(
    mock_repo, mock_db_session, mock_conveying_party
):
    input_data = SAVE_INPUT_DATA.copy()
    input_data["conveying_party_id"] = 10

    mock_filter = MagicMock()
    mock_filter.first.return_value = mock_conveying_party
    mock_db_session.query.return_value.filter.return_value = mock_filter

    result = mock_repo.save_conveying_parties(
        input_data, type_id=1, commit_flag=True
    )

    mock_db_session.query.assert_called_once()
    mock_db_session.query.return_value.filter.assert_called_once()
    mock_filter.first.assert_called_once()
    mock_conveying_party.set_conveying_party.assert_called_once_with(input_data, 1)
    mock_db_session.add.assert_not_called()
    mock_db_session.commit.assert_called_once()
    mock_db_session.flush.assert_not_called()
    mock_db_session.refresh.assert_not_called()
    assert result == mock_conveying_party.to_dict.return_value


