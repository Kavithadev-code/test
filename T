import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError

# Import your actual classes
from your_module.assignment_repository import AssignmentRepository
from your_module.exceptions import DatabaseException


class DummyAssignment:
    def __init__(self, assignment_id=None):
        self.assignment_id = assignment_id


@pytest.fixture
def mock_session():
    return MagicMock()


@pytest.fixture
def repo(mock_session):
    return AssignmentRepository(session=mock_session)


# ✅ Test: New assignment (assignment_id is None)
def test_save_assignment_new_success(repo, mock_session):
    assignment = DummyAssignment(assignment_id=None)

    result = repo.save_assignment(assignment)

    mock_session.add.assert_called_once_with(assignment)
    mock_session.flush.assert_called_once()
    mock_session.refresh.assert_called_once_with(assignment)
    assert result == assignment


# ✅ Test: Existing assignment (assignment_id NOT None)
def test_save_assignment_existing(repo, mock_session):
    assignment = DummyAssignment(assignment_id=123)

    result = repo.save_assignment(assignment)

    mock_session.add.assert_not_called()
    mock_session.flush.assert_not_called()
    mock_session.refresh.assert_not_called()
    assert result == assignment


# ❌ Test: Exception handling (rollback path)
def test_save_assignment_exception(repo, mock_session):
    assignment = DummyAssignment(assignment_id=None)

    mock_session.add.side_effect = SQLAlchemyError("DB error")

    with pytest.raises(DatabaseException) as exc:
        repo.save_assignment(assignment)

    mock_session.rollback.assert_called_once()
    assert "Error saving Assignment details" in str(exc.value)


# ✅ Test: Logger info called
@patch("your_module.assignment_repository.logger")
def test_save_assignment_logs_info(mock_logger, repo, mock_session):
    assignment = DummyAssignment(assignment_id=None)

    repo.save_assignment(assignment)

    mock_logger.info.assert_called_once_with("Save Update Assignment")


# ✅ Test: Logger error called on exception
@patch("your_module.assignment_repository.logger")
def test_save_assignment_logs_error(mock_logger, repo, mock_session):
    assignment = DummyAssignment(assignment_id=None)
    mock_session.add.side_effect = SQLAlchemyError("DB error")

    with pytest.raises(DatabaseException):
        repo.save_assignment(assignment)

    mock_logger.error.assert_called()