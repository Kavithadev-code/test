def search_public_patent_data(result, requested_data):
    assignment_details_data = []

    data_filter = (requested_data or {}).get("dataFilter", {}) or {}
    sort_by = data_filter.get("sortBy")
    sort_order = (data_filter.get("sortOrder") or "asc").lower()

    hits = result.get("hits", {}).get("hits", [])

    for hit in hits:
        source = hit.get("_source", {}) or {}

        public_patent_properties = source.get("public_patent_properties", []) or []
        correspondent = source.get("correspondent")
        assignor = source.get("assignor", []) or []
        assignee = source.get("assignee", []) or []
        processing_details = source.get("processing_details", {}) or {}

        for prop in public_patent_properties:
            assignment_details = {
                "sequence_number": prop.get("sequence_number"),
                "application_number": prop.get("application_number"),
                "patent_number": prop.get("patent_number"),
                "international_registration_number": prop.get("international_registration_number"),
                "pgpub_number": prop.get("pgpub_number"),
                "pct_number": prop.get("pct_number"),
                "invention_title": prop.get("invention_title"),
                "inventors_name": prop.get("inventors_name"),
                "filing_date": prop.get("filing_date"),
                "international_application_date": prop.get("international_application_date"),
                "international_publication_date": prop.get("international_publication_date"),
                "issue_date": prop.get("issue_date"),
                "publication_date": prop.get("publication_date"),
                "reel_number": source.get("reel_number"),
                "frame_number": source.get("frame_number"),
                "conveyance_type_text": source.get("conveyance_type_text"),
                "conveyance_type_code": source.get("conveyance_type_code"),
                "correspondent": correspondent,
                "assignor": assignor,
                "assignee": assignee,
                "processing_details": processing_details,
                "mail_date": source.get("mail_date"),
                "receipt_date": source.get("receipt_date"),
                "recordation_date": source.get("recordation_date"),
                "page_count": source.get("page_count"),
                "image_available_status_code": source.get("image_available_status_code"),
            }
            assignment_details_data.append(assignment_details)

    if sort_by == "assignmentSequence":
        total_records = len(assignment_details_data)

        if sort_order == "desc":
            for idx, item in enumerate(assignment_details_data):
                item["assignmentSequence"] = total_records - idx
        else:
            assignment_details_data = list(reversed(assignment_details_data))
            for idx, item in enumerate(assignment_details_data, start=1):
                item["assignmentSequence"] = idx

    return assignment_details_data