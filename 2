import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError

from repositories.assignment.correspondence_repository import CorrespondenceRepository
from exception.database_exception import DatabaseException


@pytest.fixture
def mock_db_session():
    return MagicMock()


@pytest.fixture
def mock_repo(mock_db_session):
    return CorrespondenceRepository(mock_db_session)


@pytest.fixture
def mock_correspondence():
    obj = MagicMock()
    obj.correspondent_id = 101
    obj.fk_assignment_id = 123
    return obj


def test_get_correspondence_info_by_correspondent_id_success(mock_repo, mock_db_session, mock_correspondence):
    query_mock = MagicMock()
    mock_db_session.query.return_value = query_mock
    query_mock.get.return_value = mock_correspondence

    with patch("repositories.assignment.correspondence_repository.Correspondent", MagicMock()):
        result = mock_repo.get_correspondence_info_by_correspondent_id(101)

    assert result == mock_correspondence
    mock_db_session.query.assert_called_once()


def test_get_correspondence_info_by_correspondent_id_returns_none(mock_repo, mock_db_session):
    query_mock = MagicMock()
    mock_db_session.query.return_value = query_mock
    query_mock.get.return_value = None

    with patch("repositories.assignment.correspondence_repository.Correspondent", MagicMock()):
        result = mock_repo.get_correspondence_info_by_correspondent_id(101)

    assert result is None
    mock_db_session.query.assert_called_once()


def test_get_correspondence_info_by_correspondent_id_db_error(mock_repo, mock_db_session):
    mock_db_session.query.side_effect = Exception("db failure")

    with patch("repositories.assignment.correspondence_repository.Correspondent", MagicMock()):
        with pytest.raises(DatabaseException) as exc_info:
            mock_repo.get_correspondence_info_by_correspondent_id(101)

    assert "Unable to get Correspondent Info" in str(exc_info.value)


def test_get_correspondence_info_by_assignment_id_success(mock_repo, mock_db_session, mock_correspondence):
    query_mock = MagicMock()
