import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError

from src.repositories.assignment.address_repository import AddressRepository


class TestAddressRepository:

    def test_save_address_info_success_when_address_id_is_none(self):
        session = MagicMock()
        repo = AddressRepository(session)

        address = MagicMock()
        address.address_id = None

        result = repo.save_address_info(address)

        session.add.assert_called_once_with(address)
        session.flush.assert_called_once()
        assert result == address

    def test_save_address_info_success_when_address_id_exists(self):
        session = MagicMock()
        repo = AddressRepository(session)

        address = MagicMock()
        address.address_id = 100

        result = repo.save_address_info(address)

        session.add.assert_not_called()
        session.flush.assert_not_called()
        assert result == address

    def test_save_address_info_exception(self):
        session = MagicMock()
        repo = AddressRepository(session)

        address = MagicMock()
        address.address_id = None
        session.add.side_effect = SQLAlchemyError("DB error")

        with pytest.raises(Exception):
            repo.save_address_info(address)

    @patch("src.repositories.assignment.address_repository.Address")
    def test_get_address_info_by_address_id_success(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        fake_address = MagicMock()
        session.query.return_value.get.return_value = fake_address

        result = repo.get_address_info_by_address_id(23)

        session.query.assert_called_once_with(mock_address)
        session.query.return_value.get.assert_called_once_with(23)
        assert result == fake_address

    @patch("src.repositories.assignment.address_repository.Address")
    def test_get_address_info_by_address_id_not_found(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        session.query.return_value.get.return_value = None

        result = repo.get_address_info_by_address_id(23)

        session.query.assert_called_once_with(mock_address)
        session.query.return_value.get.assert_called_once_with(23)
        assert result is None

    @patch("src.repositories.assignment.address_repository.Address")
    def test_get_address_info_by_address_id_exception(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        session.query.return_value.get.side_effect = Exception("failure")

        with pytest.raises(Exception):
            repo.get_address_info_by_address_id(23)

        session.query.assert_called_once_with(mock_address)
        session.query.return_value.get.assert_called_once_with(23)

    @patch("src.repositories.assignment.address_repository.Address")
    def test_upsert_address_existing(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        existing_address = MagicMock()
        session.query.return_value.get.return_value = existing_address

        address_info = {
            "address_id": 1,
            "city": "Fairfax",
            "state": "VA"
        }

        result = repo.upsert_address(address_info)

        session.query.assert_called_once_with(mock_address)
        session.query.return_value.get.assert_called_once_with(1)
        existing_address.set_address.assert_called_once_with(address_info)
        session.flush.assert_called_once()
        assert result == existing_address

    @patch("src.repositories.assignment.address_repository.Address")
    def test_upsert_address_new_when_address_id_is_none(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        new_address = MagicMock()
        mock_address.from_dict.return_value = new_address
        repo.save_address_info = MagicMock(return_value=new_address)

        address_info = {
            "address_id": None,
            "city": "Fairfax",
            "state": "VA"
        }

        result = repo.upsert_address(address_info)

        mock_address.from_dict.assert_called_once_with(address_info)
        repo.save_address_info.assert_called_once_with(new_address)
        session.flush.assert_called_once()
        assert result == new_address

    @patch("src.repositories.assignment.address_repository.Address")
    def test_upsert_address_new_when_address_id_missing(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        new_address = MagicMock()
        mock_address.from_dict.return_value = new_address
        repo.save_address_info = MagicMock(return_value=new_address)

        address_info = {
            "city": "Reston",
            "state": "VA"
        }

        result = repo.upsert_address(address_info)

        mock_address.from_dict.assert_called_once_with(address_info)
        repo.save_address_info.assert_called_once_with(new_address)
        session.flush.assert_called_once()
        assert result == new_address

    @patch("src.repositories.assignment.address_repository.Address")
    def test_upsert_address_exception_when_existing_lookup_fails(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        session.query.return_value.get.side_effect = SQLAlchemyError("lookup failed")

        with pytest.raises(Exception):
            repo.upsert_address({"address_id": 1})

        session.query.assert_called_once_with(mock_address)
        session.query.return_value.get.assert_called_once_with(1)

    @patch("src.repositories.assignment.address_repository.Address")
    def test_upsert_address_exception_when_from_dict_fails(self, mock_address):
        session = MagicMock()
        repo = AddressRepository(session)

        mock_address.from_dict.side_effect = SQLAlchemyError("from_dict failed")

        with pytest.raises(Exception):
            repo.upsert_address({"address_id": None, "city": "Herndon"})

        mock_address.from_dict.assert_called_once_with(
            {"address_id": None, "city": "Herndon"}
        )