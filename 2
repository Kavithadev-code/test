import pytest
from unittest.mock import MagicMock, patch
from sqlalchemy.exc import SQLAlchemyError

from repositories.assignment.individual_repository import IndividualRepository
from exception.database_exception import DatabaseException


class TestIndividualRepository:

    @pytest.fixture
    def mock_db_session(self):
        return MagicMock()

    @pytest.fixture
    def mock_repo(self, mock_db_session):
        return IndividualRepository(mock_db_session)

    @pytest.fixture
    def mock_individual(self):
        individual = MagicMock()
        individual.individual_id = None
        return individual

    def test_save_individual_info_success_when_individual_id_is_none(
        self, mock_repo, mock_db_session, mock_individual
    ):
        result = mock_repo.save_individual_info(mock_individual)

        assert result == mock_individual
        mock_db_session.add.assert_called_once_with(mock_individual)
        mock_db_session.flush.assert_called_once()
        mock_db_session.refresh.assert_called_once_with(mock_individual)

    def test_save_individual_info_success_when_individual_id_exists(
        self, mock_repo, mock_db_session
    ):
        individual = MagicMock()
        individual.individual_id = 101

        result = mock_repo.save_individual_info(individual)

        assert result == individual
        mock_db_session.add.assert_not_called()
        mock_db_session.flush.assert_called_once()
        mock_db_session.refresh.assert_called_once_with(individual)

    def test_save_individual_info_sqlalchemy_error_on_add(
        self, mock_repo, mock_db_session, mock_individual
    ):
        mock_db_session.add.side_effect = SQLAlchemyError("db add failed")

        with pytest.raises(DatabaseException) as exc_info:
            mock_repo.save_individual_info(mock_individual)

        mock_db_session.rollback.assert_called_once()
        assert "error saving individual name details" in str(exc_info.value).lower()

    def test_save_individual_info_sqlalchemy_error_on_flush(
        self, mock_repo, mock_db_session, mock_individual
    ):
        mock_db_session.flush.side_effect = SQLAlchemyError("db flush failed")

        with pytest.raises(DatabaseException) as exc_info:
            mock_repo.save_individual_info(mock_individual)

        mock_db_session.rollback.assert_called_once()
        assert "error saving individual name details" in str(exc_info.value).lower()

    def test_upsert_individual_updates_existing_individual(
        self, mock_repo, mock_db_session
    ):
        individual_data = {
            "individual_id": 123,
            "first_name": "Kim",
            "last_name": "Hwi",
        }

        existing_individual = MagicMock()
        query_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.get.return_value = existing_individual

        result = mock_repo.upsert_individual(individual_data)

        assert result == existing_individual
        mock_db_session.query.assert_called_once()
        query_mock.get.assert_called_once_with(123)
        existing_individual.set_individual.assert_called_once_with(individual_data)
        mock_db_session.flush.assert_called_once()
        mock_db_session.refresh.assert_called_once_with(existing_individual)

    def test_upsert_individual_creates_new_individual(
        self, mock_repo
    ):
        individual_data = {
            "first_name": "Kim",
            "last_name": "Hwi",
        }

        saved_individual = MagicMock()

        with patch("repositories.assignment.individual_repository.Individual") as mock_individual_cls:
            new_individual = MagicMock()
            mock_individual_cls.from_dict.return_value = new_individual
            mock_repo.save_individual_info = MagicMock(return_value=saved_individual)

            result = mock_repo.upsert_individual(individual_data)

        assert result == saved_individual
        mock_individual_cls.from_dict.assert_called_once_with(individual_data)
        mock_repo.save_individual_info.assert_called_once_with(new_individual)

    def test_upsert_individual_creates_new_individual_when_individual_id_is_none(
        self, mock_repo
    ):
        individual_data = {
            "individual_id": None,
            "first_name": "Kim",
            "last_name": "Hwi",
        }

        saved_individual = MagicMock()

        with patch("repositories.assignment.individual_repository.Individual") as mock_individual_cls:
            new_individual = MagicMock()
            mock_individual_cls.from_dict.return_value = new_individual
            mock_repo.save_individual_info = MagicMock(return_value=saved_individual)

            result = mock_repo.upsert_individual(individual_data)

        assert result == saved_individual
        mock_individual_cls.from_dict.assert_called_once_with(individual_data)
        mock_repo.save_individual_info.assert_called_once_with(new_individual)

    def test_upsert_individual_sqlalchemy_error_raises_database_exception(
        self, mock_repo, mock_db_session
    ):
        individual_data = {
            "individual_id": 123,
            "first_name": "Bad",
            "last_name": "Data",
        }

        mock_db_session.query.side_effect = SQLAlchemyError("query failed")

        with pytest.raises(DatabaseException) as exc_info:
            mock_repo.upsert_individual(individual_data)

        mock_db_session.rollback.assert_called_once()
        assert "error saving individual details" in str(exc_info.value).lower()

    def test_get_individual_info_by_individual_id_success(
        self, mock_repo, mock_db_session
    ):
        individual_id = 123
        expected_individual = MagicMock()

        query_mock = MagicMock()
        mock_db_session.query.return_value = query_mock
        query_mock.get.return_value = expected_individual

        result = mock_repo.get_individual_info_by_individual_id(individual_id)

        assert result == expected_individual
        mock_db_session.query.assert_called_once()
        query_mock.get.assert_called_once_with(individual_id)

    def test_get_individual_info_by_individual_id_returns_none(
        self, mock_repo, mock_db_session
    ):
        individual_id = 123

        query_mock = MagicMock()
        mock_db_session.query.return_value = query_mock
        query_mock.get.return_value = None

        result = mock_repo.get_individual_info_by_individual_id(individual_id)

        assert result is None
        mock_db_session.query.assert_called_once()
        query_mock.get.assert_called_once_with(individual_id)

    def test_get_individual_info_by_individual_id_exception_raises_database_exception(
        self, mock_repo, mock_db_session
    ):
        individual_id = 123
        mock_db_session.query.side_effect = Exception("unexpected failure")

        with pytest.raises(DatabaseException) as exc_info:
            mock_repo.get_individual_info_by_individual_id(individual_id)

        assert "unable to get individual names info" in str(exc_info.value).lower()
