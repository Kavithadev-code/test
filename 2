def test_save_correspondence_info_success_when_correspondent_id_is_none(mock_repo, mock_db_session):
    correspondence = MagicMock()
    correspondence.correspondent_id = None

    result = mock_repo.save_correspondence_info(correspondence)

    assert result == correspondence
    mock_db_session.add.assert_called_once_with(correspondence)
    mock_db_session.flush.assert_called_once()


def test_save_correspondence_info_success_when_correspondent_id_exists(mock_repo, mock_db_session):
    correspondence = MagicMock()
    correspondence.correspondent_id = 999

    result = mock_repo.save_correspondence_info(correspondence)

    assert result == correspondence
    mock_db_session.add.assert_not_called()
    mock_db_session.flush.assert_not_called()


def test_save_correspondence_info_sqlalchemy_error(mock_repo, mock_db_session):
    correspondence = MagicMock()
    correspondence.correspondent_id = None
    mock_db_session.add.side_effect = SQLAlchemyError("insert failed")

    with pytest.raises(DatabaseException) as exc_info:
        mock_repo.save_correspondence_info(correspondence)

    assert "Error saving Assignment details" in str(exc_info.value)
    mock_db_session.add.assert_called_once_with(correspondence)
