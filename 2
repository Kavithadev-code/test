    def test_save_receiving_parties_updates_existing_party(
        self, mock_repo, mock_db_session, receiving_party_data_with_id
    ):
        existing_party = MagicMock()
        existing_party.to_dict.return_value = {
            "receiving_party_id": 123,
            "assignment_id": 456,
            "name": "Updated Party"
        }

        query_mock = MagicMock()
        filter_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.filter.return_value = filter_mock
        filter_mock.first.return_value = existing_party

        result = mock_repo.save_receiving_parties(
            receiving_party_data_with_id,
            type_id=1,
            address_id=10,
            domestic_individual_id=20,
            domestic_address_info_id=30
        )

        existing_party.set_receiving_party.assert_called_once_with(
            receiving_party_data_with_id, 1, 10, 20, 30
        )
        existing_party.to_dict.assert_called_once()
        assert result == {
            "receiving_party_id": 123,
            "assignment_id": 456,
            "name": "Updated Party"
        }

    def test_save_receiving_parties_creates_new_party(
        self, mock_repo, mock_db_session, receiving_party_data_without_id
    ):
        with patch("repositories.assignment.receiving_party_repository.ReceivingParty") as mock_receiving_party_cls:
            new_entity = MagicMock()
            new_entity.to_dict.return_value = {
                "receiving_party_id": 999,
                "assignment_id": 456,
                "name": "New Receiving Party"
            }
            mock_receiving_party_cls.from_dict.return_value = new_entity

            result = mock_repo.save_receiving_parties(
                receiving_party_data_without_id,
                type_id=1,
                address_id=10,
                domestic_individual_id=20,
                domestic_address_info_id=30
            )

            mock_receiving_party_cls.from_dict.assert_called_once_with(
                receiving_party_data_without_id, 1, 10, 20, 30
            )
            mock_db_session.add.assert_called_once_with(new_entity)
            mock_db_session.flush.assert_called_once()
            new_entity.to_dict.assert_called_once()
            assert result == {
                "receiving_party_id": 999,
                "assignment_id": 456,
                "name": "New Receiving Party"
            }

