    def test_delete_by_id_success(self, mock_repo, mock_db_session):
        existing_party = MagicMock()

        query_mock = MagicMock()
        filter_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.filter.return_value = filter_mock
        filter_mock.first.return_value = existing_party

        result = mock_repo.delete_by_id(123)

        assert result is True
        mock_db_session.delete.assert_called_once_with(existing_party)
        mock_db_session.commit.assert_called_once()

    def test_delete_by_id_returns_false_when_not_found(self, mock_repo, mock_db_session):
        query_mock = MagicMock()
        filter_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.filter.return_value = filter_mock
        filter_mock.first.return_value = None

        result = mock_repo.delete_by_id(123)

        assert result is False
        mock_db_session.delete.assert_not_called()
        mock_db_session.commit.assert_not_called()

    def test_delete_by_id_exception_rolls_back_and_raises(self, mock_repo, mock_db_session):
        mock_db_session.query.side_effect = Exception("db failure")

        with pytest.raises(Exception):
            mock_repo.delete_by_id(123)

        mock_db_session.rollback.assert_called_once()

