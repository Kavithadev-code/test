    def test_delete_by_id_success(self, mock_repo, mock_db_session):
        receiving_party_id = 123
        expected_obj = MagicMock()

        query_mock = MagicMock()
        filter_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.filter.return_value = filter_mock
        filter_mock.first.return_value = expected_obj

        result = mock_repo.delete_by_id(receiving_party_id)

        assert result is True
        mock_db_session.query.assert_called_once()
        query_mock.filter.assert_called_once()
        filter_mock.first.assert_called_once()
        mock_db_session.delete.assert_called_once_with(expected_obj)
        mock_db_session.commit.assert_called_once()

    def test_delete_by_id_returns_false_when_not_found(self, mock_repo, mock_db_session):
