    def test_save_receiving_parties_updates_existing_party(self, mock_repo, mock_db_session, receiving_party_data):
        existing_party = MagicMock()
        existing_party.to_dict.return_value = {"receiving_party_id": 123, "name": "Updated"}

        query_mock = MagicMock()
        filter_mock = MagicMock()

        mock_db_session.query.return_value = query_mock
        query_mock.filter.return_value = filter_mock
        filter_mock.first.return_value = existing_party

        result = mock_repo.save_receiving_parties(
            receiving_party_data,
            type_id=1,
            address_id=10,
            domestic_individual_id=20,
            domestic_address_info_id=30
        )

        assert result == {"receiving_party_id": 123, "name": "Updated"}
        mock_db_session.query.assert_called_once()
        query_mock.filter.assert_called_once()
        filter_mock.first.assert_called_once()
        existing_party.set_receiving_party.assert_called_once_with(
            receiving_party_data, 1, 10, 20, 30
        )
        existing_party.to_dict.assert_called_once()
        mock_db_session.add.assert_not_called()
        mock_db_session.flush.assert_not_called()

    def test_save_receiving_parties_creates_new_party(self, mock_repo, mock_db_session):
        receiving_party_data = {
            "receiving_party_id": None,
            "assignment_id": 456,
            "name": "New Party"
        }

        saved_entity = MagicMock()
        saved_entity.to_dict.return_value = {"receiving_party_id": 999, "name": "New Party"}

        with patch("repositories.assignment.receiving_party_repository.ReceivingParty") as mock_receiving_party_cls:
            new_entity = MagicMock()
            mock_receiving_party_cls.from_dict.return_value = new_entity
            mock_db_session.add.side_effect = lambda obj: None
            mock_db_session.flush.side_effect = lambda: None

            result = mock_repo.save_receiving_parties(
                receiving_party_data,
                type_id=1,
                address_id=10,
                domestic_individual_id=20,
                domestic_address_info_id=30
            )

        mock_receiving_party_cls.from_dict.assert_called_once_with(
            receiving_party_data, 1, 10, 20, 30
        )
        mock_db_session.add.assert_called_once_with(new_entity)
        mock_db_session.flush.assert_called_once()

